#!/usr/bin/env python3
"""Core compiler CLI — build, ir, cir subcommands."""
import sys, os, subprocess, argparse

sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..', 'bootstrap'))

from corec.frontend.lexer import Lexer
from corec.frontend.parser import Parser
from corec.frontend.name_resolver import NameResolver
from corec.frontend.desugar import MatchDesugarer
from corec.frontend.type_checker import TypeChecker
from corec.frontend.ir_gen import IRGen
from corec.backend.arm64_asm import Arm64AsmGen
from corec.utils.module_loader import resolve_imports
from corec.ir.cir import extract_all


def compile_pipeline(src_path):
    """Run full frontend pipeline: lex → parse → resolve → desugar → typeck → IR.

    Returns (Module, errors) or raises on unrecoverable errors.
    """
    with open(src_path, encoding='utf-8') as f:
        src = f.read()
    lex = Lexer(src)
    tokens = lex.tokenize()
    ast = Parser(tokens).parse_compilation_unit()
    resolve_imports(ast, source_path=src_path)
    resolver = NameResolver()
    resolver.resolve(ast)
    desugarer = MatchDesugarer(resolver.symtab)
    ast = desugarer.desugar(ast)
    checker = TypeChecker(resolver.symtab)
    checker.check(ast)
    errors = resolver.errors + checker.errors
    ir_gen = IRGen(resolver.symtab)
    mod = ir_gen.gen_module(ast)
    return mod, errors


def cmd_build(args):
    mod, errors = compile_pipeline(args.source)
    if errors:
        print("Errors:", errors, file=sys.stderr)
        sys.exit(1)

    # Dump .ccr (linear CFG IR)
    from corec.syntax.ast import StructDecl
    struct_fields = {}
    for func in mod.functions:
        pass  # rebuild struct_fields if needed later
    # Temporarily re-parse to get struct fields
    with open(args.source) as f:
        src = f.read()
    lex = Lexer(src)
    ast = Parser(lex.tokenize()).parse_compilation_unit()
    struct_fields = {}
    for decl in ast.declarations:
        if isinstance(decl, StructDecl):
            struct_fields[decl.name] = [(fname, str(ftype)) for fname, ftype in decl.fields]

    ccr_path = args.source.replace('.cr', '.ccr')
    with open(ccr_path, 'w') as f:
        for func in mod.functions:
            f.write(f"Function: {func.name}\n")
            for blk in func.blocks:
                f.write(f"  Block: {blk.name}\n")
                for instr in blk.instrs:
                    f.write(f"    {instr}\n")
    print(f"  CCR -> {ccr_path}")

    asm_gen = Arm64AsmGen(mod, struct_fields)
    asm_code = asm_gen.generate()
    out_path = args.output
    asm_path = out_path + ".s"
    with open(asm_path, 'w') as f:
        f.write(asm_code)
    obj_path = out_path + ".o"
    subprocess.run(['as', '-o', obj_path, asm_path], check=True)
    subprocess.run(['ld', '-o', out_path, obj_path], check=True)
    print(f"Compiled {args.source} -> {out_path}")


def cmd_ir(args):
    mod, errors = compile_pipeline(args.source)
    if errors:
        print("Errors:", errors, file=sys.stderr)
        sys.exit(1)
    graphs = extract_all(mod)
    cir_path = args.source.replace('.cr', '.cir')
    with open(cir_path, 'w') as f:
        for name, g in graphs.items():
            f.write(f"// Function: {name}\n")
            f.write(g.to_dot())
            f.write("\n")
    print(f" -> {cir_path} ({len(graphs)} functions)")


def cmd_cir(args):
    mod, errors = compile_pipeline(args.source)
    if errors:
        print("Errors:", errors, file=sys.stderr)
        sys.exit(1)
    ccr_path = args.source.replace('.cr', '.ccr')
    with open(ccr_path, 'w') as f:
        for func in mod.functions:
            f.write(f"Function: {func.name}\n")
            for blk in func.blocks:
                f.write(f"  Block: {blk.name}\n")
                for instr in blk.instrs:
                    f.write(f"    {instr}\n")
    print(f" -> {ccr_path}")


def main():
    parser = argparse.ArgumentParser(description="Core compiler")
    sub = parser.add_subparsers(dest="command", required=True)

    p_build = sub.add_parser("build", help="Compile .cr → ARM64 native binary")
    p_build.add_argument("source", metavar="SOURCE.cr")
    p_build.add_argument("-o", "--output", required=True, help="Output binary path")
    p_build.set_defaults(func=cmd_build)

    p_ir = sub.add_parser("ir", help="Generate dataflow graph IR (.cir) dump")
    p_ir.add_argument("source", metavar="SOURCE.cr")
    p_ir.set_defaults(func=cmd_ir)

    p_cir = sub.add_parser("cir", help="Generate linear CFG IR (.ccr) dump")
    p_cir.add_argument("source", metavar="SOURCE.cr")
    p_cir.set_defaults(func=cmd_cir)

    args = parser.parse_args()
    args.func(args)


if __name__ == '__main__':
    main()
