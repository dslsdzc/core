// === src/compiler/ast.core ===
// === ast.core ===
// Core compiler - shared type definitions and constants

// Token kind constants
let T_EOF: int = 0;
let T_IDENT: int = 1;
let T_INT: int = 2;
let T_FLOAT: int = 3;
let T_STRING: int = 4;
let T_FN: int = 5;
let T_LET: int = 6;
let T_MUT: int = 7;
let T_IF: int = 8;
let T_ELSE: int = 9;
let T_LOOP: int = 10;
let T_FOR: int = 11;
let T_IN: int = 12;
let T_RETURN: int = 13;
let T_BREAK: int = 14;
let T_CONTINUE: int = 15;
let T_STRUCT: int = 16;
let T_ENUM: int = 17;
let T_IMPL: int = 18;
let T_PUB: int = 19;
let T_TRUE: int = 20;
let T_FALSE: int = 21;
let T_MOVE: int = 22;
let T_SELF: int = 23;
let T_LPAREN: int = 24;
let T_RPAREN: int = 25;
let T_LBRACE: int = 26;
let T_RBRACE: int = 27;
let T_COMMA: int = 28;
let T_SEMI: int = 29;
let T_COLON: int = 30;
let T_DOT: int = 31;
let T_ARROW: int = 32;
let T_EQ: int = 33;
let T_EQEQ: int = 34;
let T_BANG: int = 35;
let T_BANGEQ: int = 36;
let T_LT: int = 37;
let T_GT: int = 38;
let T_LTEQ: int = 39;
let T_GTEQ: int = 40;
let T_PLUS: int = 41;
let T_MINUS: int = 42;
let T_STAR: int = 43;
let T_SLASH: int = 44;
let T_ANDAND: int = 45;
let T_PIPEPIPE: int = 46;
let T_AMPERSAND: int = 47;
let T_UNDERSCORE: int = 48;
let T_UNIT: int = 49;
let T_PATHSEP: int = 50;
let T_LBRACKET: int = 51;
let T_RBRACKET: int = 52;
let T_MATCH: int = 53;
let T_FATARROW: int = 54;
let T_PERCENT: int = 55;
let T_CHAR: int = 56;
let T_WHILE: int = 57;
let T_DOTDOT: int = 58;
let T_TYPE: int = 59;
let T_MOD: int = 60;
let T_IMPORT: int = 61;
let T_AS: int = 62;
let T_GO: int = 63;
let T_AWAIT: int = 64;
let T_UNSAFE: int = 65;
let T_INTERFACE: int = 66;

// Type constants
let TY_INT: int = 0;
let TY_FLOAT: int = 1;
let TY_BOOL: int = 2;
let TY_STRING: int = 3;
let TY_UNIT: int = 4;
let TY_NEVER: int = 5;
let TY_CHAR: int = 6;

// Storage limits
let MAX_FUNCS: int = 128;
let MAX_STRUCTS: int = 64;
let MAX_ENUMS: int = 32;
let MAX_VARIANTS: int = 16;
let MAX_FIELDS: int = 16;
let MAX_PARAMS: int = 16;
let MAX_LOOPS: int = 16;

// Compiler buffer sizes
let MAX_TOKENS: int = 8192;
let MAX_AST: int = 16384;
let MAX_STRS: int = 2048;
let MAX_ERRS: int = 128;
let MAX_ASM: int = 8192;
let MAX_BLOCK_STMTS: int = 16384; // total statements across all blocks

// Token struct
struct Token {
    kind: int,
    lexeme: string,
    int_val: int,
    line: int,
    col: int,
}

// Function signature (for call resolution)
struct FuncInfo {
    name: string,
    param_count: int,
    param_types: [int; 16],
    return_type: int,
    ast_node: int,  // index into ast array for the fn body
}

// Struct layout
struct StructInfo {
    name: string,
    field_names: [string; 16],
    field_types: [int; 16],
    field_count: int,
}

// Enum variant description
struct EnumVariant {
    name: string,
    types: [int; 16],  // TY_* for each field
    type_count: int,
}

// Enum layout
struct EnumInfo {
    name: string,
    variants: [EnumVariant; 16],
    variant_count: int,
}

// Loop context (for break/continue)
struct LoopInfo {
    start_label: string,
    end_label: string,
}

// Block statement index storage: sequential statement indices for each block
// EXPR_BLOCK uses a=start_idx_into_g_block_stmts, b=stmt_count
let mut g_block_stmts: [int; MAX_BLOCK_STMTS];
let mut g_block_stmt_count: int;

// Flat AST node - representation varies by kind
struct ASTNode {
    kind: int,
    a: int,       // child/index slot 1
    b: int,       // child/index slot 2
    c: int,       // child/index slot 3
    int_val: int, // integer literal or string table ref
    type_val: int, // resolved type (TY_*)
    data: int,     // extra data (mutable flag, etc.)
    line: int,
    col: int,
}

// AST node kind constants
let EXPR_NONE: int = 0;
let EXPR_INT: int = 1;      // int_val = value
let EXPR_FLOAT: int = 27;   // int_val = value (as scaled int)
let EXPR_STRING: int = 2;   // int_val = str table index
let EXPR_BOOL: int = 3;     // int_val = 0/1
let EXPR_IDENT: int = 4;    // int_val = name str table index
let EXPR_BINARY: int = 5;   // a=left, b=right, c=opcode
let EXPR_UNARY: int = 6;    // a=operand, c=opcode
let EXPR_CALL: int = 7;     // a=func, b=first arg idx, c=arg count
let EXPR_BLOCK: int = 8;    // a=g_block_stmts start, b=stmt count
let EXPR_IF: int = 9;       // a=cond, b=then, c=else (-1 if none)
let EXPR_LOOP: int = 10;    // a=body
let EXPR_LET: int = 11;     // a=name idx, b=type, c=value, data=is_mut
let EXPR_RETURN: int = 12;  // a=value expr (-1 if none)
let EXPR_FIELD: int = 13;   // a=object, int_val=field name idx
let EXPR_INDEX: int = 14;   // a=object, b=index
let EXPR_ASSIGN: int = 15;  // a=target, b=value
let EXPR_STRUCT: int = 16;  // a=type name idx, b=first field, c=field count
let EXPR_FN: int = 17;      // a=name idx, b=first param, c=param count, d=body, data=return_type
let EXPR_PARAM: int = 18;   // a=name idx, int_val=type
let EXPR_ARRAY: int = 19;   // a=first elem, b=elem count
let EXPR_BREAK: int = 20;
let EXPR_CONTINUE: int = 21;
let EXPR_FOR: int = 22;     // a=var name idx, b=iter, c=body
let EXPR_MATCH: int = 23;   // a=expr, b=first arm, c=arm count
let EXPR_ARM: int = 24;     // a=pattern, b=body
let EXPR_WILDCARD: int = 25;
let EXPR_ENUMPAT: int = 26; // a=name idx, b=first subpat, c=subpat count
let EXPR_STMT: int = 28;   // a=inner expr; expression used as statement (with ;), returns unit
let EXPR_CHAR: int = 29;   // int_val = codepoint
let EXPR_WHILE: int = 30;  // a=cond, b=body
let EXPR_RANGE: int = 31;  // a=start, b=end
let EXPR_MOVE: int = 32;     // a=expr being moved
let EXPR_ENUM_CONSTRUCTOR: int = 37; // a=name idx, b=first arg, c=arg count
let EXPR_REFTYPE: int = 38;   // a=inner type node, data=mut flag (for &T / &mut T in type position)

// Field representation in struct literal: two consecutive AST nodes
// (name_idx, value_idx, line=line, col=col)
struct FieldPair {
    name_idx: int,
    value_idx: int,
    line: int,
    col: int,
}

// Binary operator codes
let OP_ADD: int = 1;
let OP_SUB: int = 2;
let OP_MUL: int = 3;
let OP_DIV: int = 4;
let OP_MOD: int = 5;
let OP_EQ: int = 6;
let OP_NE: int = 7;
let OP_LT: int = 8;
let OP_GT: int = 9;
let OP_LE: int = 10;
let OP_GE: int = 11;
let OP_AND: int = 12;
let OP_OR: int = 13;
let OP_ASSIGN: int = 14;

// Unary operator codes
let UOP_NEG: int = 1;
let UOP_NOT: int = 2;
let UOP_REF: int = 3;
let UOP_DEREF: int = 4;

// Type table pre-allocated indices (for checker type system)
let TI_INT: int = 0;
let TI_FLOAT: int = 1;
let TI_BOOL: int = 2;
let TI_STR: int = 3;
let TI_UNIT: int = 4;
let TI_NEVER: int = 5;
let TI_CHAR: int = 6;

// Type table entry kinds
let TYP_BASE: int = 0;   // data = TY_* constant
let TYP_NAMED: int = 1;  // data = name string index
let TYP_ARRAY: int = 2;  // data = element type idx, extra = size
let TYP_REF: int = 3;    // data = inner type idx, extra = mut flag

// Symbol kinds for checker
let SYM_FN: int = 0;
let SYM_TYPE: int = 1;
let SYM_LOCAL: int = 2;
let SYM_PARAM: int = 3;
let SYM_GLOBAL: int = 4;

// Additional size limits
let MAX_SYMS: int = 512;
let MAX_TYPES: int = 128;
let MAX_SCOPES: int = 32;
let MAX_IREXPRS: int = 4096;
let MAX_IRINSTRUCTIONS: int = 16384;
let MAX_BLOCKS: int = 512;
let MAX_LABELS: int = 512;

// IR instruction opcodes
let IR_NOP: int = 0;
let IR_CONST: int = 1;
let IR_BINARY: int = 2;
let IR_UNARY: int = 3;
let IR_CALL: int = 4;
let IR_RETURN: int = 5;
let IR_ALLOC: int = 6;
let IR_ALLOC_STRUCT: int = 7;
let IR_ALLOC_ARRAY: int = 8;
let IR_STORE: int = 9;
let IR_LOAD: int = 10;
let IR_LOAD_FIELD: int = 11;
let IR_STORE_FIELD: int = 12;
let IR_LOAD_INDEX: int = 13;
let IR_STORE_INDEX: int = 14;
let IR_LOAD_INDEX_VAR: int = 15;
let IR_STORE_INDEX_VAR: int = 16;
let IR_MAKE_ENUM: int = 17;
let IR_REF: int = 18;
let IR_BRANCH: int = 19;
let IR_JUMP: int = 20;
let IR_LABEL: int = 21;
let IR_PHI: int = 22;

// IR instruction (flat representation)
struct IRInstr {
    opcode: int,
    dest: int,      // destination var index
    src1: int,      // source var/val 1
    src2: int,      // source var/val 2
    src3: int,      // extra data (label, field name, etc.)
    type_kind: int, // type info
}

// === src/compiler/ir/nodes.core ===
// IR instruction type definitions for Core compiler backend

// IRR variables (temp storage during codegen)
struct IRVar {
    name: string,
    id: int,
    type_kind: int,
}

// Basic block in IR
struct IRBlock {
    name: int,
    start_instr: int,
    instr_count: int,
}

// ARM64 register mapping
struct RegInfo {
    reg: int,
    is_used: int,
}

// === src/compiler/lexer.core ===
// Lexer: tokenizes Core source code using string built-ins

// Global compiler state
let mut g_source: string;
let mut g_tokens: [Token; MAX_TOKENS];
let mut g_token_count: int;
let mut g_pos: int;
let mut g_line: int;
let mut g_col: int;
let mut g_errors: [string; MAX_ERRS];
let mut g_error_count: int;

fn add_error(msg: string) {
    if g_error_count < MAX_ERRS {
        g_errors[g_error_count] = msg;
        g_error_count = g_error_count + 1;
    }
}

fn cur_char() -> string {
    if g_pos >= __builtin_str_len(g_source) {
        return "\0";
    }
    return __builtin_str_get(g_source, g_pos);
}

fn advance() {
    let c = cur_char();
    if c == "\n" {
        g_line = g_line + 1;
        g_col = 1;
    } else {
        g_col = g_col + 1;
    }
    g_pos = g_pos + 1;
}

fn peek() -> string {
    if g_pos + 1 >= __builtin_str_len(g_source) {
        return "\0";
    }
    return __builtin_str_get(g_source, g_pos + 1);
}

fn skip_whitespace() {
    loop {
        let c = cur_char();
        if c == " " || c == "\t" || c == "\r" || c == "\n" {
            advance();
        } else {
            break;
        }
    }
}

fn add_token(kind: int) {
    if g_token_count >= MAX_TOKENS { return; }
    g_tokens[g_token_count] = Token {
        kind: kind,
        lexeme: "",
        int_val: 0,
        line: g_line,
        col: g_col,
    };
    g_token_count = g_token_count + 1;
}

fn add_token_str(kind: int, lexeme: string) {
    if g_token_count >= MAX_TOKENS { return; }
    g_tokens[g_token_count] = Token {
        kind: kind,
        lexeme: lexeme,
        int_val: 0,
        line: g_line,
        col: g_col,
    };
    g_token_count = g_token_count + 1;
}

fn add_token_int(kind: int, val: int) {
    if g_token_count >= MAX_TOKENS { return; }
    g_tokens[g_token_count] = Token {
        kind: kind,
        lexeme: "",
        int_val: val,
        line: g_line,
        col: g_col,
    };
    g_token_count = g_token_count + 1;
}

fn is_digit(c: string) -> bool {
    c >= "0" && c <= "9"
}

fn is_alpha(c: string) -> bool {
    (c >= "a" && c <= "z") || (c >= "A" && c <= "Z") || c == "_"
}

fn is_ident_char(c: string) -> bool {
    is_alpha(c) || is_digit(c)
}

fn lookup_keyword(ident: string) -> int {
    if ident == "fn" { return T_FN; }
    if ident == "let" { return T_LET; }
    if ident == "mut" { return T_MUT; }
    if ident == "if" { return T_IF; }
    if ident == "else" { return T_ELSE; }
    if ident == "loop" { return T_LOOP; }
    if ident == "for" { return T_FOR; }
    if ident == "in" { return T_IN; }
    if ident == "return" { return T_RETURN; }
    if ident == "break" { return T_BREAK; }
    if ident == "continue" { return T_CONTINUE; }
    if ident == "struct" { return T_STRUCT; }
    if ident == "enum" { return T_ENUM; }
    if ident == "impl" { return T_IMPL; }
    if ident == "pub" { return T_PUB; }
    if ident == "true" { return T_TRUE; }
    if ident == "false" { return T_FALSE; }
    if ident == "match" { return T_MATCH; }
    if ident == "move" { return T_MOVE; }
    if ident == "self" { return T_SELF; }
    if ident == "unit" { return T_UNIT; }
    if ident == "char" { return T_CHAR; }
    if ident == "while" { return T_WHILE; }
    if ident == "import" { return T_IMPORT; }
    if ident == "mod" { return T_MOD; }
    if ident == "type" { return T_TYPE; }
    if ident == "as" { return T_AS; }
    if ident == "go" { return T_GO; }
    if ident == "await" { return T_AWAIT; }
    if ident == "unsafe" { return T_UNSAFE; }
    if ident == "interface" { return T_INTERFACE; }
    return T_IDENT;
}

fn tokenize() {
    g_token_count = 0;
    g_pos = 0;
    g_line = 1;
    g_col = 1;

    skip_whitespace();

    loop {
        if g_pos >= __builtin_str_len(g_source) { break; }
        let c = cur_char();

        // Single-line comment //
        if c == "/" && peek() == "/" {
            loop {
                advance();
                if g_pos >= __builtin_str_len(g_source) { break; }
                if cur_char() == "\n" {
                    advance();
                    break;
                }
            }
            skip_whitespace();
            continue;
        }

        // Block comment /* */
        if c == "/" && peek() == "*" {
            advance(); advance();
            loop {
                if g_pos >= __builtin_str_len(g_source) { break; }
                if cur_char() == "*" && peek() == "/" {
                    advance(); advance();
                    break;
                }
                advance();
            }
            skip_whitespace();
            continue;
        }

        let start_line = g_line;
        let start_col = g_col;

        // Identifier or keyword
        if is_alpha(c) {
            let start = g_pos;
            advance();
            loop {
                let c2 = cur_char();
                if is_ident_char(c2) { advance(); } else { break; }
            }
            let ident = __builtin_str_sub(g_source, start, g_pos - start);
            let kind = lookup_keyword(ident);
            add_token_str(kind, ident);
            skip_whitespace();
            continue;
        }

        // Number literal
        if is_digit(c) {
            let start = g_pos;
            advance();
            let mut kind = T_INT;
            loop {
                let c2 = cur_char();
                if is_digit(c2) { advance(); }
                else if c2 == "." {
                    kind = T_FLOAT;
                    advance();
                } else { break; }
            }
            let num_str = __builtin_str_sub(g_source, start, g_pos - start);
            let val = __builtin_str_to_int(num_str);
            add_token_int(kind, val);
            skip_whitespace();
            continue;
        }

        // String literal
        if c == "\"" {
            advance();
            let start = g_pos;
            loop {
                if g_pos >= __builtin_str_len(g_source) { break; }
                if cur_char() == "\"" { break; }
                if cur_char() == "\\" {
                    advance();
                    if g_pos < __builtin_str_len(g_source) { advance(); }
                } else {
                    advance();
                }
            }
            let str_val = __builtin_str_sub(g_source, start, g_pos - start);
            advance();
            add_token_str(T_STRING, str_val);
            skip_whitespace();
            continue;
        }

        // Char literal
        if c == "'" {
            advance();
            let mut ch = "\0";
            if cur_char() == "\\" {
                advance();
                let esc = cur_char();
                if esc == "n" { ch = "\n"; }
                else if esc == "t" { ch = "\t"; }
                else if esc == "r" { ch = "\r"; }
                else if esc == "'" { ch = "'"; }
                else if esc == "\\" { ch = "\\"; }
                else { ch = esc; }
                advance();
            } else {
                ch = cur_char();
                advance();
            }
            if cur_char() == "'" { advance(); }
            add_token_str(T_CHAR, ch);
            skip_whitespace();
            continue;
        }

        // Multi-character operators
        if c == "=" && peek() == "=" { advance(); advance(); add_token(T_EQEQ); skip_whitespace(); continue; }
        if c == "!" && peek() == "=" { advance(); advance(); add_token(T_BANGEQ); skip_whitespace(); continue; }
        if c == "<" && peek() == "=" { advance(); advance(); add_token(T_LTEQ); skip_whitespace(); continue; }
        if c == ">" && peek() == "=" { advance(); advance(); add_token(T_GTEQ); skip_whitespace(); continue; }
        if c == "&" && peek() == "&" { advance(); advance(); add_token(T_ANDAND); skip_whitespace(); continue; }
        if c == "|" && peek() == "|" { advance(); advance(); add_token(T_PIPEPIPE); skip_whitespace(); continue; }
        if c == "-" && peek() == ">" { advance(); advance(); add_token(T_ARROW); skip_whitespace(); continue; }
        if c == "=" && peek() == ">" { advance(); advance(); add_token(T_FATARROW); skip_whitespace(); continue; }
        if c == ":" && peek() == ":" { advance(); advance(); add_token(T_PATHSEP); skip_whitespace(); continue; }
        if c == "." && peek() == "." { advance(); advance(); add_token(T_DOTDOT); skip_whitespace(); continue; }

        // Single-character tokens
        if c == "(" { advance(); add_token(T_LPAREN); skip_whitespace(); continue; }
        if c == ")" { advance(); add_token(T_RPAREN); skip_whitespace(); continue; }
        if c == "{" { advance(); add_token(T_LBRACE); skip_whitespace(); continue; }
        if c == "}" { advance(); add_token(T_RBRACE); skip_whitespace(); continue; }
        if c == "[" { advance(); add_token(T_LBRACKET); skip_whitespace(); continue; }
        if c == "]" { advance(); add_token(T_RBRACKET); skip_whitespace(); continue; }
        if c == "," { advance(); add_token(T_COMMA); skip_whitespace(); continue; }
        if c == ";" { advance(); add_token(T_SEMI); skip_whitespace(); continue; }
        if c == ":" { advance(); add_token(T_COLON); skip_whitespace(); continue; }
        if c == "." { advance(); add_token(T_DOT); skip_whitespace(); continue; }
        if c == "=" { advance(); add_token(T_EQ); skip_whitespace(); continue; }
        if c == "!" { advance(); add_token(T_BANG); skip_whitespace(); continue; }
        if c == "<" { advance(); add_token(T_LT); skip_whitespace(); continue; }
        if c == ">" { advance(); add_token(T_GT); skip_whitespace(); continue; }
        if c == "+" { advance(); add_token(T_PLUS); skip_whitespace(); continue; }
        if c == "-" { advance(); add_token(T_MINUS); skip_whitespace(); continue; }
        if c == "*" { advance(); add_token(T_STAR); skip_whitespace(); continue; }
        if c == "/" { advance(); add_token(T_SLASH); skip_whitespace(); continue; }
        if c == "%" { advance(); add_token(T_PERCENT); skip_whitespace(); continue; }
        if c == "&" { advance(); add_token(T_AMPERSAND); skip_whitespace(); continue; }
        if c == "_" { advance(); add_token(T_UNDERSCORE); skip_whitespace(); continue; }

        // Unknown character
        advance();
        skip_whitespace();
    }

    add_token(T_EOF);
}

// === src/compiler/parser.core ===
// Parser: recursive descent with flat AST output

// Global state for parser
let mut g_ast: [ASTNode; MAX_AST];
let mut g_ast_count: int;
let mut g_strs: [string; MAX_STRS];
let mut g_str_count: int;
let mut g_token_pos: int;
let mut g_funcs: [FuncInfo; MAX_FUNCS];
let mut g_func_count: int;
let mut g_structs: [StructInfo; MAX_STRUCTS];
let mut g_struct_count: int;
let mut g_enums: [EnumInfo; MAX_ENUMS];
let mut g_enum_count: int;
let mut g_loop_stack: [LoopInfo; MAX_LOOPS];
let mut g_loop_depth: int;
let mut g_global_lets: [int; MAX_AST];
let mut g_global_let_count: int;

struct TypeAlias {
    name_idx: int,
    type_node: int,
}
let mut g_type_aliases: [TypeAlias; MAX_TYPES];
let mut g_type_alias_count: int;

struct MethodEntry {
    struct_ni: int,  // struct name index
    method_ni: int,  // method name index
    mangled_ni: int, // mangled function name index ("Struct.method")
}
let mut g_methods: [MethodEntry; MAX_FUNCS];
let mut g_method_count: int;

fn str_intern(s: string) -> int {
    let mut i = 0;
    loop {
        if i >= g_str_count { break; }
        if g_strs[i] == s { return i; }
        i = i + 1;
    }
    if g_str_count < MAX_STRS {
        g_strs[g_str_count] = s;
        g_str_count = g_str_count + 1;
    }
    return g_str_count - 1;
}

fn alloc_node(kind: int, a: int, b: int, c: int, iv: int, tv: int, d: int, line: int, col: int) -> int {
    let idx = g_ast_count;
    if idx >= MAX_AST { return 0; }
    g_ast[idx] = ASTNode { kind = kind, a = a, b = b, c = c, int_val = iv, type_val = tv, data = d, line = line, col = col };
    g_ast_count = idx + 1;
    return idx;
}

fn cur_tok() -> int { return g_token_pos; }
fn tok_k(p: int) -> int { return g_tokens[p].kind; }
fn tok_lx(p: int) -> string { return g_tokens[p].lexeme; }
fn tok_iv(p: int) -> int { return g_tokens[p].int_val; }
fn tok_ln(p: int) -> int { return g_tokens[p].line; }
fn tok_cl(p: int) -> int { return g_tokens[p].col; }

fn advance_tok() -> int {
    let t = cur_tok();
    if tok_k(t) != T_EOF { g_token_pos = t + 1; }
    return t;
}

fn check(k: int) -> bool {
    if tok_k(cur_tok()) == k { return true; } else { return false; }
}

fn expect(k: int) -> int {
    let t = cur_tok();
    if tok_k(t) == k { return advance_tok(); }
    return t;
}

// --- Type parsing ---
fn parse_type() -> int {
    let t = cur_tok();
    if tok_k(t) == T_LBRACKET {
        advance_tok();
        let inner = parse_type();
        if check(T_SEMI) {
            advance_tok();
            let sz = advance_tok();
            advance_tok();
            return alloc_node(EXPR_ARRAY, inner, 0, 0, tok_iv(sz), 0, 0, tok_ln(t), tok_cl(t));
        }
        advance_tok();
        return inner;
    }
    if tok_k(t) == T_LPAREN {
        advance_tok();
        let typ = parse_type();
        advance_tok();
        return typ;
    }
    if tok_k(t) == T_AMPERSAND {
        advance_tok();
        let mut is_mut = 0;
        if tok_k(cur_tok()) == T_MUT {
            is_mut = 1;
            advance_tok();
        }
        let inner = parse_type();
        return alloc_node(EXPR_REFTYPE, inner, 0, 0, is_mut, 0, 0, tok_ln(t), tok_cl(t));
    }
    let lex = tok_lx(t);
    advance_tok();
    if lex == "int" { return alloc_node(0, 0, 0, 0, 0, TY_INT, 0, tok_ln(t), tok_cl(t)); }
    if lex == "float" { return alloc_node(0, 0, 0, 0, 0, TY_FLOAT, 0, tok_ln(t), tok_cl(t)); }
    if lex == "bool" { return alloc_node(0, 0, 0, 0, 0, TY_BOOL, 0, tok_ln(t), tok_cl(t)); }
    if lex == "string" { return alloc_node(0, 0, 0, 0, 0, TY_STRING, 0, tok_ln(t), tok_cl(t)); }
    if lex == "unit" { return alloc_node(0, 0, 0, 0, 0, TY_UNIT, 0, tok_ln(t), tok_cl(t)); }
    if lex == "char" { return alloc_node(0, 0, 0, 0, 0, TY_CHAR, 0, tok_ln(t), tok_cl(t)); }
    if lex == "never" { return alloc_node(0, 0, 0, 0, 0, TY_NEVER, 0, tok_ln(t), tok_cl(t)); }
    let ni = str_intern(lex);
    return alloc_node(EXPR_IDENT, 0, 0, 0, ni, 0, 0, tok_ln(t), tok_cl(t));
}

fn unpack_type(typ: int) -> int {
    if g_ast[typ].kind == 0 { return g_ast[typ].type_val; }
    return 0;
}

// --- Expression parsing ---
fn prec(k: int) -> int {
    if k == T_EQ { return 1; }
    if k == T_PIPEPIPE { return 2; }
    if k == T_ANDAND { return 3; }
    if k == T_EQEQ || k == T_BANGEQ { return 4; }
    if k == T_LT || k == T_GT || k == T_LTEQ || k == T_GTEQ { return 5; }
    if k == T_PLUS || k == T_MINUS { return 6; }
    if k == T_STAR || k == T_SLASH || k == T_PERCENT { return 7; }
    return -1;
}

fn tok2op(k: int) -> int {
    if k == T_PLUS { return OP_ADD; }
    if k == T_MINUS { return OP_SUB; }
    if k == T_STAR { return OP_MUL; }
    if k == T_SLASH { return OP_DIV; }
    if k == T_PERCENT { return OP_MOD; }
    if k == T_EQEQ { return OP_EQ; }
    if k == T_BANGEQ { return OP_NE; }
    if k == T_LT { return OP_LT; }
    if k == T_GT { return OP_GT; }
    if k == T_LTEQ { return OP_LE; }
    if k == T_GTEQ { return OP_GE; }
    if k == T_ANDAND { return OP_AND; }
    if k == T_PIPEPIPE { return OP_OR; }
    return 0;
}

fn parse_expr() -> int {
    let left = parse_binary(0);
    if check(T_DOTDOT) {
        let t = advance_tok();
        let right = parse_expr();
        return alloc_node(EXPR_RANGE, left, right, 0, 0, 0, 0, tok_ln(t), tok_cl(t));
    }
    return left;
}

fn parse_binary(mp: int) -> int {
    let mut left = parse_unary();
    loop {
        let t = cur_tok();
        let k = tok_k(t);
        let p = prec(k);
        if p < mp { break; }
        advance_tok();
        let right = parse_binary(p + 1);
        let op = tok2op(k);
        // Convert assignment to EXPR_ASSIGN
        if k == T_EQ {
            left = alloc_node(EXPR_ASSIGN, left, right, 0, 0, 0, 0, tok_ln(t), tok_cl(t));
        } else {
            left = alloc_node(EXPR_BINARY, left, right, op, 0, 0, 0, tok_ln(t), tok_cl(t));
        }
    }
    return left;
}

fn parse_unary() -> int {
    let t = cur_tok();
    if tok_k(t) == T_MINUS {
        advance_tok();
        let op = parse_unary();
        return alloc_node(EXPR_UNARY, op, 0, UOP_NEG, 0, 0, 0, tok_ln(t), tok_cl(t));
    }
    if tok_k(t) == T_AMPERSAND {
        advance_tok();
        let mut is_mut = 0;
        if tok_k(cur_tok()) == T_MUT {
            is_mut = 1;
            advance_tok();
        }
        let op = parse_unary();
        return alloc_node(EXPR_UNARY, op, 0, UOP_REF, is_mut, 0, 0, tok_ln(t), tok_cl(t));
    }
    if tok_k(t) == T_BANG {
        advance_tok();
        let op = parse_unary();
        return alloc_node(EXPR_UNARY, op, 0, UOP_NOT, 0, 0, 0, tok_ln(t), tok_cl(t));
    }
    if tok_k(t) == T_MOVE {
        advance_tok();
        let op = parse_unary();
        return alloc_node(EXPR_MOVE, op, 0, 0, 0, 0, 0, tok_ln(t), tok_cl(t));
    }
    return parse_postfix();
}

fn parse_postfix() -> int {
    let mut node = parse_primary();
    loop {
        let t = cur_tok();
        if tok_k(t) == T_LPAREN {
            advance_tok();
            let af = -1;
            let mut ac = 0;
            if !check(T_RPAREN) {
                let af = parse_expr();
                ac = 1;
                loop {
                    if !check(T_COMMA) { break; }
                    advance_tok();
                    ac = ac + 1;
                }
            }
            advance_tok();
            // Check if this is an enum constructor (uppercase ident + parenthesized args)
            let mut is_enum_con = 0;
            if g_ast[node].kind == EXPR_IDENT {
                let name_idx = g_ast[node].int_val;
                let name = g_strs[name_idx];
                let c = __builtin_str_get(name, 0);
                if c >= "A" && c <= "Z" {
                    is_enum_con = 1;
                }
            }
            if is_enum_con == 1 {
                let name_idx = g_ast[node].int_val;
                node = alloc_node(EXPR_ENUM_CONSTRUCTOR, name_idx, af, ac, 0, 0, 0, tok_ln(t), tok_cl(t));
            } else {
                node = alloc_node(EXPR_CALL, node, af, ac, 0, 0, 0, tok_ln(t), tok_cl(t));
            }
            continue;
        }
        if tok_k(t) == T_DOT {
            advance_tok();
            let f = advance_tok();
            let ni = str_intern(tok_lx(f));
            node = alloc_node(EXPR_FIELD, node, 0, 0, ni, 0, 0, tok_ln(t), tok_cl(t));
            continue;
        }
        if tok_k(t) == T_LBRACKET {
            advance_tok();
            let idx = parse_expr();
            advance_tok();
            node = alloc_node(EXPR_INDEX, node, idx, 0, 0, 0, 0, tok_ln(t), tok_cl(t));
            continue;
        }
        break;
    }
    return node;
}

fn is_upper_first(s: string) -> bool {
    let c = __builtin_str_get(s, 0);
    if c >= "A" && c <= "Z" { return true; }
    return false;
}

fn parse_primary() -> int {
    let t = cur_tok();
    if tok_k(t) == T_INT {
        advance_tok();
        return alloc_node(EXPR_INT, 0, 0, 0, tok_iv(t), TY_INT, 0, tok_ln(t), tok_cl(t));
    }
    if tok_k(t) == T_STRING {
        advance_tok();
        return alloc_node(EXPR_STRING, 0, 0, 0, str_intern(tok_lx(t)), TY_STRING, 0, tok_ln(t), tok_cl(t));
    }
    if tok_k(t) == T_TRUE { advance_tok(); return alloc_node(EXPR_BOOL, 0, 0, 0, 1, TY_BOOL, 0, tok_ln(t), tok_cl(t)); }
    if tok_k(t) == T_FALSE { advance_tok(); return alloc_node(EXPR_BOOL, 0, 0, 0, 0, TY_BOOL, 0, tok_ln(t), tok_cl(t)); }
    if tok_k(t) == T_IDENT || tok_k(t) == T_SELF || tok_k(t) == T_UNDERSCORE {
        advance_tok();
        let name = tok_lx(t);
        let ni = str_intern(name);
        if check(T_LBRACE) {
            advance_tok();
            let ff = -1;
            let mut fc = 0;
            loop {
                if check(T_RBRACE) { break; }
                let ft = advance_tok();
                let fni = str_intern(tok_lx(ft));
                advance_tok();
                let fv = parse_expr();
                alloc_node(EXPR_IDENT, 0, 0, 0, fni, 0, 0, tok_ln(ft), tok_cl(ft));
                alloc_node(0, fv, 0, 0, 0, 0, 0, tok_ln(ft), tok_cl(ft));
                if fc == 0 { ff = g_ast_count - 2; }
                fc = fc + 1;
                if check(T_COMMA) { advance_tok(); }
            }
            advance_tok();
            return alloc_node(EXPR_STRUCT, ni, ff, fc, 0, 0, 0, tok_ln(t), tok_cl(t));
        }
        return alloc_node(EXPR_IDENT, 0, 0, 0, ni, 0, 0, tok_ln(t), tok_cl(t));
    }
    if tok_k(t) == T_LPAREN {
        advance_tok();
        let e = parse_expr();
        advance_tok();
        return e;
    }
    if tok_k(t) == T_CHAR {
        advance_tok();
        return alloc_node(EXPR_CHAR, 0, 0, 0, str_intern(tok_lx(t)), TY_CHAR, 0, tok_ln(t), tok_cl(t));
    }
    if tok_k(t) == T_LBRACE { return parse_block(); }
    if tok_k(t) == T_IF { return parse_if_expr(); }
    if tok_k(t) == T_WHILE { return parse_while_expr(); }
    if tok_k(t) == T_LOOP { return parse_loop_expr(); }
    if tok_k(t) == T_FOR { return parse_for_expr(); }
    if tok_k(t) == T_MATCH { return parse_match_expr(); }
    if tok_k(t) == T_LBRACKET {
        advance_tok();
        let ef = -1;
        let mut ec = 0;
        if !check(T_RBRACKET) {
            ef = parse_expr();
            ec = 1;
            loop {
                if !check(T_COMMA) { break; }
                advance_tok();
                ec = ec + 1;
            }
        }
        advance_tok();
        return alloc_node(EXPR_ARRAY, ef, ec, 0, 0, 0, 0, tok_ln(t), tok_cl(t));
    }
    add_error("Unexpected token in expression");
    return 0;
}

fn parse_block() -> int {
    let t = advance_tok();
    let mut local_stmts: [int; 512];
    let mut sc = 0;
    loop {
        if check(T_RBRACE) || check(T_EOF) { break; }
        let st = parse_stmt();
        if sc < 512 {
            local_stmts[sc] = st;
        }
        sc = sc + 1;
    }
    advance_tok();
    // Flush to global block_stmts array (isolated from nested blocks)
    let si = g_block_stmt_count;
    let mut i = 0;
    loop {
        if i >= sc { break; }
        if g_block_stmt_count < MAX_BLOCK_STMTS {
            g_block_stmts[g_block_stmt_count] = local_stmts[i];
            g_block_stmt_count = g_block_stmt_count + 1;
        }
        i = i + 1;
    }
    return alloc_node(EXPR_BLOCK, si, sc, 0, 0, 0, 0, tok_ln(t), tok_cl(t));
}

fn parse_stmt() -> int {
    let t = cur_tok();
    if tok_k(t) == T_LET {
        advance_tok();
        let mut im = 0;
        if check(T_MUT) { im = 1; advance_tok(); }
        let nt = advance_tok();
        let ni = str_intern(tok_lx(nt));
        let mut tn = -1;
        if check(T_COLON) { advance_tok(); tn = parse_type(); }
        let mut val = -1;
        if check(T_EQ) { advance_tok(); val = parse_expr(); }
        advance_tok();
        return alloc_node(EXPR_LET, ni, tn, val, 0, 0, im, tok_ln(t), tok_cl(t));
    }
    if tok_k(t) == T_RETURN {
        advance_tok();
        let mut val = -1;
        if !check(T_SEMI) && !check(T_RBRACE) { val = parse_expr(); }
        if check(T_SEMI) { advance_tok(); }
        return alloc_node(EXPR_RETURN, val, 0, 0, 0, 0, 0, tok_ln(t), tok_cl(t));
    }
    if tok_k(t) == T_BREAK {
        advance_tok();
        if check(T_SEMI) { advance_tok(); }
        return alloc_node(EXPR_BREAK, 0, 0, 0, 0, 0, 0, tok_ln(t), tok_cl(t));
    }
    if tok_k(t) == T_CONTINUE {
        advance_tok();
        if check(T_SEMI) { advance_tok(); }
        return alloc_node(EXPR_CONTINUE, 0, 0, 0, 0, 0, 0, tok_ln(t), tok_cl(t));
    }
    let e = parse_expr();
    if check(T_SEMI) {
        advance_tok();
        return alloc_node(EXPR_STMT, e, 0, 0, 0, 0, 0, tok_ln(t), tok_cl(t));
    }
    return e;
}

fn parse_if_expr() -> int {
    let t = advance_tok();
    let cond = parse_expr();
    let tb = parse_block();
    let mut eb = -1;
    if check(T_ELSE) {
        advance_tok();
        if check(T_IF) { eb = parse_if_expr(); }
        else { eb = parse_block(); }
    }
    return alloc_node(EXPR_IF, cond, tb, eb, 0, 0, 0, tok_ln(t), tok_cl(t));
}

fn parse_loop_expr() -> int {
    let t = advance_tok();
    let body = parse_block();
    return alloc_node(EXPR_LOOP, body, 0, 0, 0, 0, 0, tok_ln(t), tok_cl(t));
}

fn parse_while_expr() -> int {
    let t = advance_tok();
    let cond = parse_expr();
    let body = parse_block();
    return alloc_node(EXPR_WHILE, cond, body, 0, 0, 0, 0, tok_ln(t), tok_cl(t));
}

fn parse_for_expr() -> int {
    let t = advance_tok();
    let vt = advance_tok();
    let vn = str_intern(tok_lx(vt));
    advance_tok();
    let iter = parse_expr();
    let body = parse_block();
    return alloc_node(EXPR_FOR, vn, iter, body, 0, 0, 0, tok_ln(t), tok_cl(t));
}

fn parse_match_expr() -> int {
    let t = advance_tok();
    let expr = parse_expr();
    advance_tok();
    let af = -1;
    let mut ac = 0;
    loop {
        if check(T_RBRACE) || check(T_EOF) { break; }
        let pat = parse_pattern();
        advance_tok();
        let body = parse_expr();
        if check(T_COMMA) { advance_tok(); }
        let n = alloc_node(EXPR_ARM, pat, body, 0, 0, 0, 0, tok_ln(t), tok_cl(t));
        if ac == 0 { af = n; }
        ac = ac + 1;
    }
    advance_tok();
    return alloc_node(EXPR_MATCH, expr, af, ac, 0, 0, 0, tok_ln(t), tok_cl(t));
}

fn parse_pattern() -> int {
    let t = cur_tok();
    if tok_k(t) == T_UNDERSCORE {
        advance_tok();
        return alloc_node(EXPR_WILDCARD, 0, 0, 0, 0, 0, 0, tok_ln(t), tok_cl(t));
    }
    if tok_k(t) == T_IDENT {
        advance_tok();
        let name = tok_lx(t);
        let ni = str_intern(name);
        if check(T_LPAREN) {
            advance_tok();
            let mut ac = 0;
            if !check(T_RPAREN) {
                ac = 1;
                loop {
                    if !check(T_COMMA) { break; }
                    advance_tok();
                    ac = ac + 1;
                }
            }
            advance_tok();
            return alloc_node(EXPR_ENUMPAT, ni, 0, ac, 0, 0, 0, tok_ln(t), tok_cl(t));
        }
        if is_upper_first(name) {
            return alloc_node(EXPR_ENUMPAT, ni, 0, 0, 0, 0, 0, tok_ln(t), tok_cl(t));
        }
        return alloc_node(EXPR_IDENT, 0, 0, 0, ni, 0, 0, tok_ln(t), tok_cl(t));
    }
    advance_tok();
    return 0;
}

// --- Top-level declarations ---

fn add_func(name: string, pc: int, rt: int, an: int) -> int {
    if g_func_count >= MAX_FUNCS { return -1; }
    let idx = g_func_count;
    g_funcs[idx] = FuncInfo { name = name, param_count = pc, param_types = [0;16], return_type = rt, ast_node = an };
    g_func_count = idx + 1;
    return idx;
}

fn add_struct(name: string) -> int {
    if g_struct_count >= MAX_STRUCTS { return -1; }
    let idx = g_struct_count;
    g_structs[idx] = StructInfo { name = name, field_names = ["";16], field_types = [0;16], field_count = 0 };
    g_struct_count = idx + 1;
    return idx;
}

fn add_enum(name: string) -> int {
    if g_enum_count >= MAX_ENUMS { return -1; }
    let idx = g_enum_count;
    g_enums[idx] = EnumInfo { name = name, variants = [EnumVariant{name="",types=[0;16],type_count=0};16], variant_count = 0 };
    g_enum_count = idx + 1;
    return idx;
}

fn parse_fn_body(fn_name: string, fn_ni: int, fn_line: int, fn_col: int) {
    advance_tok(); // (
    let mut pf = -1;
    let mut pc = 0;
    if !check(T_RPAREN) {
        pf = g_ast_count;
        loop {
            // Handle self/&self/&mut self params
            if tok_k(cur_tok()) == T_SELF {
                let pt = advance_tok();
                alloc_node(EXPR_PARAM, str_intern("self"), 0, 0, 1, 0, 0, tok_ln(pt), tok_cl(pt));
                pc = pc + 1;
                if !check(T_COMMA) { break; }
                advance_tok();
                continue;
            }
            if tok_k(cur_tok()) == T_AMPERSAND && tok_k(cur_tok()+1) == T_SELF {
                let pt = advance_tok();
                advance_tok();
                alloc_node(EXPR_PARAM, str_intern("self"), 0, 0, 2, 0, 0, tok_ln(pt), tok_cl(pt));
                pc = pc + 1;
                if !check(T_COMMA) { break; }
                advance_tok();
                continue;
            }
            let pt = advance_tok();
            let pn = str_intern(tok_lx(pt));
            advance_tok();
            let pty = parse_type();
            alloc_node(EXPR_PARAM, pn, 0, 0, 0, unpack_type(pty), 0, tok_ln(pt), tok_cl(pt));
            pc = pc + 1;
            if !check(T_COMMA) { break; }
            advance_tok();
        }
    }
    advance_tok(); // )
    advance_tok(); // ->
    let rt = parse_type();
    let rtv = unpack_type(rt);

    let mut body = -1;
    if check(T_LBRACE) {
        body = parse_block();
    } else {
        advance_tok(); // =
        body = parse_expr();
        advance_tok(); // ;
    }

    let fn_node = alloc_node(EXPR_FN, fn_ni, pf, pc, rtv, 0, body, fn_line, fn_col);
    add_func(fn_name, pc, rtv, fn_node);
}

fn parse_declaration() {
    let mut ip = 0;
    if check(T_PUB) { ip = 1; advance_tok(); }

    // fn
    if check(T_FN) {
        let t = advance_tok();
        let nt = advance_tok();
        let name = tok_lx(nt);
        let ni = str_intern(name);
        parse_fn_body(name, ni, tok_ln(t), tok_cl(t));
        return;
    }

    // struct
    if check(T_STRUCT) {
        let t = advance_tok();
        let nt = advance_tok();
        let name = tok_lx(nt);
        advance_tok();

        let si = add_struct(name);
        if si >= 0 {
            let mut fc = 0;
            loop {
                if check(T_RBRACE) { break; }
                let ft = advance_tok();
                let fn2 = tok_lx(ft);
                g_structs[si].field_names[fc] = fn2;
                advance_tok();
                let fty = parse_type();
                g_structs[si].field_types[fc] = unpack_type(fty);
                fc = fc + 1;
                if check(T_COMMA) { advance_tok(); }
            }
            g_structs[si].field_count = fc;
        }
        advance_tok();
        return;
    }

    // enum
    if check(T_ENUM) {
        let t = advance_tok();
        let nt = advance_tok();
        let name = tok_lx(nt);
        advance_tok();

        let ei = add_enum(name);
        if ei >= 0 {
            let mut vc = 0;
            loop {
                if check(T_RBRACE) { break; }
                let vt = advance_tok();
                let vname = tok_lx(vt);
                g_enums[ei].variants[vc].name = vname;
                let mut tc = 0;
                if check(T_LPAREN) {
                    advance_tok();
                    loop {
                        if check(T_RPAREN) { break; }
                        let fty = parse_type();
                        g_enums[ei].variants[vc].types[tc] = unpack_type(fty);
                        tc = tc + 1;
                        if !check(T_COMMA) { break; }
                        advance_tok();
                    }
                    advance_tok();
                }
                g_enums[ei].variants[vc].type_count = tc;
                vc = vc + 1;
                if check(T_COMMA) { advance_tok(); }
            }
            g_enums[ei].variant_count = vc;
        }
        advance_tok();
        return;
    }

    // impl block
    if check(T_IMPL) {
        let t = advance_tok();
        let type_nt = advance_tok();
        let type_name = tok_lx(type_nt);
        let type_ni = str_intern(type_name);
        advance_tok(); // {
        loop {
            if check(T_RBRACE) { break; }
            if check(T_FN) {
                let ft = advance_tok();
                let method_nt = advance_tok();
                let method_name = tok_lx(method_nt);
                let method_ni = str_intern(method_name);
                let mangled = type_name + "." + method_name;
                let mangled_ni = str_intern(mangled);
                parse_fn_body(mangled, mangled_ni, tok_ln(ft), tok_cl(ft));
                // Register in method lookup table
                if g_method_count < MAX_FUNCS {
                    g_methods[g_method_count] = MethodEntry { struct_ni = type_ni, method_ni = method_ni, mangled_ni = mangled_ni };
                    g_method_count = g_method_count + 1;
                }
            } else {
                advance_tok();
            }
        }
        advance_tok(); // }
        return;
    }

    // type alias
    if check(T_TYPE) {
        advance_tok();
        let nt = advance_tok();
        let name_idx = str_intern(tok_lx(nt));
        advance_tok();
        let type_node = parse_type();
        advance_tok(); // ;
        if g_type_alias_count < MAX_TYPES {
            g_type_aliases[g_type_alias_count] = TypeAlias { name_idx = name_idx, type_node = type_node };
            g_type_alias_count = g_type_alias_count + 1;
        }
        return;
    }

    // let (global)
    if check(T_LET) {
        advance_tok();
        let mut im = 0;
        if check(T_MUT) { im = 1; advance_tok(); }
        let nt = advance_tok();
        let ni = str_intern(tok_lx(nt));
        let mut tn = -1;
        if check(T_COLON) { advance_tok(); tn = parse_type(); }
        let mut val = -1;
        if check(T_EQ) { advance_tok(); val = parse_expr(); }
        advance_tok();
        let node = alloc_node(EXPR_LET, ni, tn, val, 0, 0, im, tok_ln(nt), tok_cl(nt));
        if g_global_let_count < MAX_AST {
            g_global_lets[g_global_let_count] = node;
            g_global_let_count = g_global_let_count + 1;
        }
        return;
    }

    advance_tok();
}

fn parse_all() {
    g_ast_count = 0;
    g_str_count = 0;
    g_token_pos = 0;
    g_func_count = 0;
    g_struct_count = 0;
    g_enum_count = 0;
    g_type_alias_count = 0;
    g_method_count = 0;
    g_loop_depth = 0;
    g_global_let_count = 0;
    g_block_stmt_count = 0;

    loop {
        if tok_k(cur_tok()) == T_EOF { break; }
        parse_declaration();
    }
}

// === src/compiler/checker.core ===
// === checker.core ===
// Two-pass name resolver + type checker for flat AST
// First pass: collect all function/struct/global declarations
// Second pass: type-check function bodies

// --- Type table ---
// Entries are 3 ints: kind, data, extra
let mut g_types: [int; MAX_TYPES * 3];
let mut g_type_count: int;

fn alloc_type(kind: int, data: int, extra: int) -> int {
    let idx = g_type_count;
    if idx < MAX_TYPES {
        g_types[idx * 3] = kind;
        g_types[idx * 3 + 1] = data;
        g_types[idx * 3 + 2] = extra;
        g_type_count = idx + 1;
    }
    return idx;
}

fn init_types() {
    g_type_count = 0;
    alloc_type(TYP_BASE, TY_INT, 0);     // TI_INT = 0
    alloc_type(TYP_BASE, TY_FLOAT, 0);   // TI_FLOAT = 1
    alloc_type(TYP_BASE, TY_BOOL, 0);    // TI_BOOL = 2
    alloc_type(TYP_BASE, TY_STRING, 0);  // TI_STR = 3
    alloc_type(TYP_BASE, TY_UNIT, 0);    // TI_UNIT = 4
    alloc_type(TYP_BASE, TY_NEVER, 0);   // TI_NEVER = 5
    alloc_type(TYP_BASE, TY_CHAR, 0);    // TI_CHAR = 6
}

fn get_type_kind(ti: int) -> int {
    if ti >= 0 && ti < g_type_count { return g_types[ti * 3]; }
    return -1;
}

fn get_type_data(ti: int) -> int {
    if ti >= 0 && ti < g_type_count { return g_types[ti * 3 + 1]; }
    return 0;
}

fn get_type_extra(ti: int) -> int {
    if ti >= 0 && ti < g_type_count { return g_types[ti * 3 + 2]; }
    return 0;
}

fn type_equal(t1: int, t2: int) -> bool {
    if t1 == t2 { return true; }
    // Compare structure for non-base types
    if t1 >= 0 && t2 >= 0 && t1 < g_type_count && t2 < g_type_count {
        let k1 = get_type_kind(t1);
        let k2 = get_type_kind(t2);
        if k1 == TYP_NAMED && k2 == TYP_NAMED {
            return get_type_data(t1) == get_type_data(t2);
        }
        if k1 == TYP_ARRAY && k2 == TYP_ARRAY {
            if type_equal(get_type_data(t1), get_type_data(t2)) {
                if get_type_extra(t1) == get_type_extra(t2) {
                    return true;
                }
            }
            return false;
        }
    }
    return false;
}

// --- Symbol table ---
struct SymEntry {
    name_idx: int,
    kind: int,
    type_idx: int,
    node_idx: int,
}

let mut g_syms: [SymEntry; MAX_SYMS];
let mut g_sym_count: int;
let mut g_scope_bounds: [int; MAX_SCOPES];
let mut g_scope_depth: int;

fn push_scope() {
    if g_scope_depth < MAX_SCOPES {
        g_scope_bounds[g_scope_depth] = g_sym_count;
        g_scope_depth = g_scope_depth + 1;
    }
}

fn pop_scope() {
    if g_scope_depth > 0 {
        g_scope_depth = g_scope_depth - 1;
        g_sym_count = g_scope_bounds[g_scope_depth];
    }
}

fn define_sym(name_idx: int, kind: int, type_idx: int, node_idx: int) {
    if g_sym_count < MAX_SYMS {
        g_syms[g_sym_count] = SymEntry { name_idx = name_idx, kind = kind, type_idx = type_idx, node_idx = node_idx };
        g_sym_count = g_sym_count + 1;
    }
}

fn lookup_sym(name_idx: int) -> int {
    let mut i = g_sym_count - 1;
    loop {
        if i < 0 { return -1; }
        if g_syms[i].name_idx == name_idx { return i; }
        i = i - 1;
    }
    return -1;
}

fn lookup_sym_global(name_idx: int) -> int {
    let mut i = g_sym_count - 1;
    loop {
        if i < 0 { return -1; }
        if g_syms[i].name_idx == name_idx && g_syms[i].kind >= SYM_FN && g_syms[i].kind <= SYM_GLOBAL { return i; }
        i = i - 1;
    }
    return -1;
}

// --- Error tracking ---
let mut g_check_errors: [string; MAX_ERRS];
let mut g_check_error_count: int;

fn check_error(msg: string) {
    if g_check_error_count < MAX_ERRS {
        g_check_errors[g_check_error_count] = msg;
        g_check_error_count = g_check_error_count + 1;
    }
}

// --- Type resolution utilities ---

fn resolve_type_node(node: int) -> int {
    if node < 0 { return TI_UNIT; }
    let n = g_ast[node];
    if n.kind == 0 {
        // Base type node: type_val = TY_*
        let tv = n.type_val;
        if tv == TY_INT { return TI_INT; }
        if tv == TY_FLOAT { return TI_FLOAT; }
        if tv == TY_BOOL { return TI_BOOL; }
        if tv == TY_STRING { return TI_STR; }
        if tv == TY_UNIT { return TI_UNIT; }
        if tv == TY_NEVER { return TI_NEVER; }
        if tv == TY_CHAR { return TI_CHAR; }
        return TI_UNIT;
    }
    if n.kind == EXPR_IDENT {
        // Named type: int_val = name string index
        let name_idx = n.int_val;
        let si = lookup_sym_global(name_idx);
        if si >= 0 && g_syms[si].kind == SYM_TYPE {
            return g_syms[si].type_idx;
        }
        // Create named type entry
        return alloc_type(TYP_NAMED, name_idx, 0);
    }
    if n.kind == EXPR_ARRAY {
        // Array type [T; N]
        let elem = resolve_type_node(n.a);
        let sz = n.int_val;
        return alloc_type(TYP_ARRAY, elem, sz);
    }
    if n.kind == EXPR_REFTYPE {
        // Reference type &T or &mut T
        let inner = resolve_type_node(n.a);
        let mut_flag = n.int_val;
        return alloc_type(TYP_REF, inner, mut_flag);
    }
    return TI_UNIT;
}

fn find_struct(name_idx: int) -> int {
    let mut i = 0;
    loop {
        if i >= g_struct_count { return -1; }
        if str_intern(g_structs[i].name) == name_idx { return i; }
        i = i + 1;
    }
    return -1;
}

fn find_enum(name_idx: int) -> int {
    let mut i = 0;
    loop {
        if i >= g_enum_count { return -1; }
        if str_intern(g_enums[i].name) == name_idx { return i; }
        i = i + 1;
    }
    return -1;
}

// --- First pass: collect all declarations ---

fn collect_decls() {
    let mut i = 0;
    // First: register all struct types
    loop {
        if i >= g_struct_count { break; }
        let name_idx = str_intern(g_structs[i].name);
        let type_idx = alloc_type(TYP_NAMED, name_idx, 0);
        define_sym(name_idx, SYM_TYPE, type_idx, -1);
        i = i + 1;
    }
    // Resolve struct field types now that all struct names are registered
    i = 0;
    loop {
        if i >= g_struct_count { break; }
        let mut j = 0;
        loop {
            if j >= g_structs[i].field_count { break; }
            // Field types were stored by parser as unpack_type() ress (TY_* or 0)
            // We need to resolve them — but they're stored as ints, not nodes.
            // For now, leave as-is; fields are resolved during type inference.
            j = j + 1;
        }
        i = i + 1;
    }
    // Register all enum types and their variant constructors
    i = 0;
    loop {
        if i >= g_enum_count { break; }
        let name_idx = str_intern(g_enums[i].name);
        let type_idx = alloc_type(TYP_NAMED, name_idx, 0);
        define_sym(name_idx, SYM_TYPE, type_idx, -1);
        // Register each variant as a function returning the enum type
        let mut vi = 0;
        loop {
            if vi >= g_enums[i].variant_count { break; }
            let vname_idx = str_intern(g_enums[i].variants[vi].name);
            define_sym(vname_idx, SYM_FN, type_idx, -1);
            vi = vi + 1;
        }
        i = i + 1;
    }

    // Register type aliases
    i = 0;
    loop {
        if i >= g_type_alias_count { break; }
        let name_idx = g_type_aliases[i].name_idx;
        let type_node = g_type_aliases[i].type_node;
        let ti = resolve_type_node(type_node);
        define_sym(name_idx, SYM_TYPE, ti, -1);
        i = i + 1;
    }

    // Register all functions
    i = 0;
    loop {
        if i >= g_func_count { break; }
        let name_idx = str_intern(g_funcs[i].name);
        let fn_node = g_funcs[i].ast_node;
        let rt = g_funcs[i].return_type;
        let rt_ti = TI_UNIT;
        if rt == TY_INT { rt_ti = TI_INT; }
        if rt == TY_FLOAT { rt_ti = TI_FLOAT; }
        if rt == TY_BOOL { rt_ti = TI_BOOL; }
        if rt == TY_STRING { rt_ti = TI_STR; }
        if rt == TY_UNIT { rt_ti = TI_UNIT; }
        define_sym(name_idx, SYM_FN, rt_ti, fn_node);
        i = i + 1;
    }
    // Register all global variables
    i = 0;
    loop {
        if i >= g_global_let_count { break; }
        let node = g_global_lets[i];
        let n = g_ast[node];
        let name_idx = n.a;  // EXPR_LET: a = name idx
        let type_node = n.b; // EXPR_LET: b = type node (-1 if none)
        let ti = TI_UNIT;
        if type_node >= 0 { ti = resolve_type_node(type_node); }
        define_sym(name_idx, SYM_GLOBAL, ti, node);
        i = i + 1;
    }
}

// --- Second pass: type-check function bodies ---

fn check_func(fi: int) {
    let fn_node = g_funcs[fi].ast_node;
    let f = g_ast[fn_node];
    let name_idx = f.a;      // EXPR_FN: a = name idx
    let first_param = f.b;   // EXPR_FN: b = first param node
    let param_count = f.c;   // EXPR_FN: c = param count
    let return_type = f.int_val;  // EXPR_FN: int_val = return TY_*
    let body = f.data;       // EXPR_FN: data = body node

    push_scope();
    // Debug: check params
    let mut debug_first = first_param;
    let mut debug_pcount = param_count;
    if debug_first < 0 { check_error("first_param < 0"); }
    if debug_pcount <= 0 { check_error("no params"); }
    // Add params to scope
    let mut pi = 0;
    let mut pn = first_param;
    loop {
        if pi >= param_count { break; }
        if pn < 0 { break; }
        let p = g_ast[pn];
        let pname_idx = p.a;       // EXPR_PARAM: a = name idx
        let ptype = p.int_val;     // EXPR_PARAM: int_val = type (TY_*)
        let ti = TI_UNIT;
        if ptype == TY_INT { ti = TI_INT; }
        if ptype == TY_FLOAT { ti = TI_FLOAT; }
        if ptype == TY_BOOL { ti = TI_BOOL; }
        if ptype == TY_STRING { ti = TI_STR; }
        if ptype == TY_CHAR { ti = TI_CHAR; }
        define_sym(pname_idx, SYM_PARAM, ti, -1);
        pi = pi + 1;
        pn = pn + 1; // params are sequential
    }
    // Check body
    if body >= 0 {
        let body_ti = infer_expr(body);
        let ret_ti = TI_UNIT;
        if return_type == TY_INT { ret_ti = TI_INT; }
        if return_type == TY_FLOAT { ret_ti = TI_FLOAT; }
        if return_type == TY_BOOL { ret_ti = TI_BOOL; }
        if return_type == TY_STRING { ret_ti = TI_STR; }
        if return_type == TY_UNIT { ret_ti = TI_UNIT; }
        if return_type == TY_CHAR { ret_ti = TI_CHAR; }
        if !type_equal(body_ti, ret_ti) && body_ti != TI_NEVER {
            check_error("Function return type mismatch");
        }
    }
    pop_scope();
}

fn check_global_let(node: int) {
    let n = g_ast[node];
    let val_node = n.c;  // EXPR_LET: c = value
    if val_node >= 0 {
        infer_expr(val_node);
    }
}

// --- Type inference ---

fn infer_expr(node: int) -> int {
    if node < 0 { return TI_UNIT; }
    let n = g_ast[node];

    if n.kind == EXPR_INT { return TI_INT; }
    if n.kind == EXPR_FLOAT { return TI_FLOAT; }
    if n.kind == EXPR_STRING { return TI_STR; }
    if n.kind == EXPR_BOOL { return TI_BOOL; }
    if n.kind == EXPR_CHAR { return TI_CHAR; }

    if n.kind == EXPR_IDENT {
        let name_idx = n.int_val;
        let si = lookup_sym(name_idx);
        if si >= 0 { return g_syms[si].type_idx; }
        check_error("Undefined name");
        return TI_NEVER;
    }

    if n.kind == EXPR_BINARY {
        let left = n.a;
        let right = n.b;
        let op = n.c;
        if op == OP_ASSIGN {
            // Assignment: left = right
            let lt = infer_expr(left);
            let rt = infer_expr(right);
            if !type_equal(lt, rt) {
                check_error("Assignment type mismatch");
            }
            return rt;
        }
        let lt = infer_expr(left);
        let rt = infer_expr(right);
        if op == OP_ADD || op == OP_SUB || op == OP_MUL || op == OP_DIV || op == OP_MOD {
            if lt == TI_FLOAT || rt == TI_FLOAT { return TI_FLOAT; }
            return TI_INT;
        }
        if op == OP_EQ || op == OP_NE || op == OP_LT || op == OP_GT || op == OP_LE || op == OP_GE {
            return TI_BOOL;
        }
        if op == OP_AND || op == OP_OR {
            return TI_BOOL;
        }
        return TI_INT;
    }

    if n.kind == EXPR_UNARY {
        let op = n.c;
        if op == UOP_NEG || op == UOP_NOT {
            return infer_expr(n.a);
        }
        if op == UOP_REF {
            let inner = infer_expr(n.a);
            let mut_flag = n.int_val;
            return alloc_type(TYP_REF, inner, mut_flag);
        }
        return infer_expr(n.a);
    }

    if n.kind == EXPR_CALL {
        let func_node = n.a;
        let first_arg = n.b;
        let arg_count = n.c;
        let mut func_ni = -1;

        // Method call: obj.method(args)
        if g_ast[func_node].kind == EXPR_FIELD {
            let obj = g_ast[func_node].a;
            let method_ni = g_ast[func_node].int_val;
            let obj_ti = infer_expr(obj);
            if obj_ti >= 0 && obj_ti < g_type_count && get_type_kind(obj_ti) == TYP_NAMED {
                let struct_ni = get_type_data(obj_ti);
                // Look up method in method table
                let mut mi = 0;
                loop {
                    if mi >= g_method_count { break; }
                    if g_methods[mi].struct_ni == struct_ni && g_methods[mi].method_ni == method_ni {
                        func_ni = g_methods[mi].mangled_ni;
                        g_ast[node].data = func_ni;
                        break;
                    }
                    mi = mi + 1;
                }
            }
            // Infer arg types
            let mut ai = 0;
            let mut an = first_arg;
            loop {
                if ai >= arg_count { break; }
                if an >= 0 { infer_expr(an); an = an + 1; }
                ai = ai + 1;
            }
            if func_ni >= 0 {
                let si = lookup_sym_global(func_ni);
                if si >= 0 && g_syms[si].kind == SYM_FN {
                    return g_syms[si].type_idx;
                }
            }
            return TI_UNIT;
        }

        // Determine function name and return type
        if g_ast[func_node].kind == EXPR_IDENT {
            func_ni = g_ast[func_node].int_val;
        }
        // Check builtins
        if func_ni >= 0 {
            let s = g_strs[func_ni];
            if s == "__builtin_str_len" { return TI_INT; }
            if s == "__builtin_str_get" { return TI_STR; }
            if s == "__builtin_str_sub" { return TI_STR; }
            if s == "__builtin_int_to_str" { return TI_STR; }
            if s == "__builtin_str_push" { return TI_STR; }
            if s == "__builtin_str_from_int" { return TI_STR; }
            if s == "__builtin_str_to_int" { return TI_INT; }
        }
        // Look up function
        if func_ni >= 0 {
            let si = lookup_sym_global(func_ni);
            if si >= 0 && g_syms[si].kind == SYM_FN {
                return g_syms[si].type_idx;  // return type
            }
        }
        // Infer arg types (for side effects)
        let mut ai = 0;
        let mut an = first_arg;
        loop {
            if ai >= arg_count { break; }
            if an >= 0 {
                infer_expr(an);
                an = an + 1;
            }
            ai = ai + 1;
        }
        return TI_UNIT;
    }

    if n.kind == EXPR_BLOCK {
        let stmt_start = n.a;
        let stmt_count = n.b;
        let mut res = TI_UNIT;
        let mut i = 0;
        loop {
            if i >= stmt_count { break; }
            let sn = g_block_stmts[stmt_start + i];
            res = infer_expr(sn);
            i = i + 1;
        }
        return res;
    }

    if n.kind == EXPR_IF {
        let cond = n.a;
        let then_node = n.b;
        let else_node = n.c;
        let cond_ti = infer_expr(cond);
        if cond_ti != TI_BOOL {
            check_error("If condition must be bool");
        }
        let then_ti = infer_expr(then_node);
        if else_node >= 0 {
            let else_ti = infer_expr(else_node);
            if !type_equal(then_ti, else_ti) {
                check_error("If branches have different types");
            }
            return then_ti;
        }
        return TI_UNIT;
    }

    if n.kind == EXPR_LOOP {
        infer_expr(n.a);
        return TI_UNIT;
    }

    if n.kind == EXPR_WHILE {
        let cond = n.a;
        let body = n.b;
        let cond_ti = infer_expr(cond);
        if cond_ti != TI_BOOL {
            check_error("While condition must be bool");
        }
        infer_expr(body);
        return TI_UNIT;
    }

    if n.kind == EXPR_FOR {
        let var_ni = n.a;
        let iter = n.b;
        let body = n.c;
        infer_expr(iter);
        push_scope();
        define_sym(var_ni, SYM_LOCAL, TI_INT, -1);
        infer_expr(body);
        pop_scope();
        return TI_UNIT;
    }

    if n.kind == EXPR_RANGE {
        infer_expr(n.a);
        infer_expr(n.b);
        return TI_INT;
    }

    if n.kind == EXPR_MATCH {
        let match_expr = n.a;
        let first_arm = n.b;
        let arm_count = n.c;
        infer_expr(match_expr);
        let mut res = TI_UNIT;
        let mut ai = 0;
        let mut an = first_arm;
        loop {
            if ai >= arm_count { break; }
            if an >= 0 {
                let arm_pat = g_ast[an].a;  // EXPR_ARM: a = pattern
                let arm_body = g_ast[an].b;  // EXPR_ARM: b = body
                // Bind pattern variables in new scope
                push_scope();
                if arm_pat >= 0 {
                    let pat = g_ast[arm_pat];
                    if pat.kind == EXPR_ENUMPAT {
                        // Bind sub-patterns
                        let sub_pat = pat.b;
                        let sub_count = pat.c;
                        let mut spi = 0;
                        let mut spn = sub_pat;
                        loop {
                            if spi >= sub_count { break; }
                            if spn >= 0 {
                                let sp = g_ast[spn];
                                if sp.kind == EXPR_IDENT {
                                    define_sym(sp.int_val, SYM_LOCAL, TI_INT, -1);
                                }
                                spn = spn + 1;
                            }
                            spi = spi + 1;
                        }
                    }
                    if pat.kind == EXPR_IDENT {
                        define_sym(pat.int_val, SYM_LOCAL, TI_INT, -1);
                    }
                }
                let arm_ti = infer_expr(arm_body);
                if ai == 0 { res = arm_ti; }
                pop_scope();
                an = an + 1;
            }
            ai = ai + 1;
        }
        return res;
    }

    if n.kind == EXPR_LET {
        let var_ni = n.a;
        let type_node = n.b;
        let val_node = n.c;
        let is_mut = n.data;
        let val_ti = TI_UNIT;
        if val_node >= 0 { val_ti = infer_expr(val_node); }
        let ti = val_ti;
        if type_node >= 0 { ti = resolve_type_node(type_node); }
        if g_strs[var_ni] != "_" {
            define_sym(var_ni, SYM_LOCAL, ti, -1);
        }
        return TI_UNIT;
    }

    if n.kind == EXPR_RETURN {
        if n.a >= 0 {
            return infer_expr(n.a);
        }
        return TI_UNIT;
    }

    if n.kind == EXPR_ENUM_CONSTRUCTOR {
        let name_idx = n.a;
        let first_arg = n.b;
        let arg_count = n.c;
        let si = lookup_sym_global(name_idx);
        if si >= 0 && g_syms[si].kind == SYM_FN {
            // Infer arg types
            let mut ai = 0;
            let mut an = first_arg;
            loop {
                if ai >= arg_count { break; }
                if an >= 0 {
                    infer_expr(an);
                    an = an + 1;
                }
                ai = ai + 1;
            }
            return g_syms[si].type_idx; // enum type
        }
        return TI_UNIT;
    }

    if n.kind == EXPR_FIELD {
        let obj = n.a;
        let field_ni = n.int_val;
        let obj_ti = infer_expr(obj);
        // Look up field in struct types
        if obj_ti >= 0 && obj_ti < g_type_count && get_type_kind(obj_ti) == TYP_NAMED {
            let struct_ni = get_type_data(obj_ti);
            let si = find_struct(struct_ni);
            if si >= 0 {
                let mut fi = 0;
                loop {
                    if fi >= g_structs[si].field_count { break; }
                    if str_intern(g_structs[si].field_names[fi]) == field_ni {
                        let ft = g_structs[si].field_types[fi];
                        if ft == TY_INT { return TI_INT; }
                        if ft == TY_FLOAT { return TI_FLOAT; }
                        if ft == TY_BOOL { return TI_BOOL; }
                        if ft == TY_STRING { return TI_STR; }
                        // Named type: need to look up
                        return TI_INT; // default
                    }
                    fi = fi + 1;
                }
            }
        }
        // Handle array element type: if obj is an array, return element type
        if obj_ti >= 0 && obj_ti < g_type_count && get_type_kind(obj_ti) == TYP_ARRAY {
            // Accessing .len or similar on array
            return TI_INT;
        }
        return TI_INT;
    }

    if n.kind == EXPR_INDEX {
        let obj = n.a;
        let idx = n.b;
        let obj_ti = infer_expr(obj);
        infer_expr(idx);
        // If object is an array, return element type
        if obj_ti >= 0 && obj_ti < g_type_count && get_type_kind(obj_ti) == TYP_ARRAY {
            return get_type_data(obj_ti);
        }
        return TI_INT;
    }

    if n.kind == EXPR_ASSIGN {
        let target = n.a;
        let val = n.b;
        let tt = infer_expr(target);
        let vt = infer_expr(val);
        if !type_equal(tt, vt) {
            check_error("Assignment type mismatch");
        }
        return vt;
    }

    if n.kind == EXPR_STRUCT {
        // Struct literal: a = name idx, b = first field node, c = field count
        let name_ni = n.a;
        let ti = alloc_type(TYP_NAMED, name_ni, 0);
        let mut fi = 0;
        let mut fn2 = n.b;
        loop {
            if fi >= n.c { break; }
            if fn2 >= 0 {
                let fnode = g_ast[fn2]; // EXPR_IDENT for field name
                let fval = g_ast[fn2 + 1]; // value expression
                infer_expr(fn2 + 1);
                fn2 = fn2 + 2; // skip name+value pair
            }
            fi = fi + 1;
        }
        return ti;
    }

    if n.kind == EXPR_ARRAY {
        // Array literal: a = first elem, b = elem count
        let elem_ti = TI_INT;
        let mut ei = 0;
        let mut en = n.a;
        loop {
            if ei >= n.b { break; }
            if en >= 0 {
                elem_ti = infer_expr(en);
                en = en + 1;
            }
            ei = ei + 1;
        }
        return alloc_type(TYP_ARRAY, elem_ti, n.b);
    }

    if n.kind == EXPR_BREAK { return TI_UNIT; }
    if n.kind == EXPR_CONTINUE { return TI_UNIT; }
    if n.kind == EXPR_WILDCARD { return TI_UNIT; }
    if n.kind == EXPR_MOVE {
        return infer_expr(n.a);
    }
    if n.kind == EXPR_STMT {
        infer_expr(n.a);
        return TI_UNIT;
    }

    return TI_UNIT;
}

// --- Main entry ---

fn check_all() {
    init_types();
    g_sym_count = 0;
    g_scope_depth = 0;
    g_check_error_count = 0;

    // First pass: collect declarations
    collect_decls();

    // Second pass: check function bodies
    let mut i = 0;
    loop {
        if i >= g_func_count { break; }
        check_func(i);
        i = i + 1;
    }

    // Check global let initializers
    i = 0;
    loop {
        if i >= g_global_let_count { break; }
        check_global_let(g_global_lets[i]);
        i = i + 1;
    }
}

// === src/compiler/ir_gen.core ===
// === ir_gen.core ===
// Flat AST to platform-independent IR instruction generation

// --- Per-function metadata arrays ---
let mut g_ir_func_name_idx: [int; MAX_FUNCS];
let mut g_ir_func_ret_type: [int; MAX_FUNCS];
let mut g_ir_func_instr_start: [int; MAX_FUNCS];
let mut g_ir_func_instr_count: [int; MAX_FUNCS];
let mut g_ir_func_var_start: [int; MAX_FUNCS];
let mut g_ir_func_var_count: [int; MAX_FUNCS];
let mut g_ir_func_param_count: [int; MAX_FUNCS];
let mut g_ir_func_count: int;

// --- IR variables ---
let mut g_ir_vars: [IRVar; MAX_IREXPRS];
let mut g_ir_var_count: int;

// --- IR instructions ---
let mut g_ir_instrs: [IRInstr; MAX_IRINSTRUCTIONS];
let mut g_ir_instr_count: int;

// --- Local variable mapping (name_idx -> ir_var_idx) ---
let mut g_ir_locals: [int; MAX_IREXPRS * 2]; // pairs: [name_idx, var_idx]
let mut g_ir_local_count: int;
let mut g_ir_local_scopes: [int; MAX_SCOPES];
let mut g_ir_local_depth: int;

// --- Global variable mapping ---
let mut g_ir_globals: [int; MAX_SYMS * 2]; // pairs: [name_idx, var_idx]
let mut g_ir_global_count: int;

// --- Labels ---
let mut g_next_label: int;

// --- Loop stack for break/continue ---
let mut g_ir_loop_header: [int; MAX_LOOPS];
let mut g_ir_loop_exit: [int; MAX_LOOPS];
let mut g_ir_loop_depth: int;

// --- String constants for .data section ---
let mut g_ir_str_consts: [int; MAX_STRS]; // string table indices used as constants
let mut g_ir_str_const_count: int;

fn new_ir_var(name: string, type_idx: int) -> int {
    let idx = g_ir_var_count;
    if idx < MAX_IREXPRS {
        g_ir_vars[idx] = IRVar { name = name, id = idx, type_kind = type_idx };
        g_ir_var_count = idx + 1;
    }
    return idx;
}

fn emit(opcode: int, dest: int, src1: int, src2: int, src3: int, type_kind: int) {
    let idx = g_ir_instr_count;
    if idx < MAX_IRINSTRUCTIONS {
        g_ir_instrs[idx] = IRInstr { opcode = opcode, dest = dest, src1 = src1, src2 = src2, src3 = src3, type_kind = type_kind };
        g_ir_instr_count = idx + 1;
    }
}

fn new_label() -> int {
    let lbl = g_next_label;
    g_next_label = g_next_label + 1;
    return lbl;
}

fn bind_local(name_idx: int, var_idx: int) {
    if g_ir_local_count < MAX_IREXPRS {
        g_ir_locals[g_ir_local_count * 2] = name_idx;
        g_ir_locals[g_ir_local_count * 2 + 1] = var_idx;
        g_ir_local_count = g_ir_local_count + 1;
    }
}

fn lookup_local(name_idx: int) -> int {
    let mut i = g_ir_local_count - 1;
    loop {
        if i < 0 { return -1; }
        if g_ir_locals[i * 2] == name_idx { return g_ir_locals[i * 2 + 1]; }
        i = i - 1;
    }
    return -1;
}

fn lookup_global(name_idx: int) -> int {
    let mut i = g_ir_global_count - 1;
    loop {
        if i < 0 { return -1; }
        if g_ir_globals[i * 2] == name_idx { return g_ir_globals[i * 2 + 1]; }
        i = i - 1;
    }
    return -1;
}

fn push_ir_scope() {
    if g_ir_local_depth < MAX_SCOPES {
        g_ir_local_scopes[g_ir_local_depth] = g_ir_local_count;
        g_ir_local_depth = g_ir_local_depth + 1;
    }
}

fn pop_ir_scope() {
    if g_ir_local_depth > 0 {
        g_ir_local_depth = g_ir_local_depth - 1;
        g_ir_local_count = g_ir_local_scopes[g_ir_local_depth];
    }
}

fn get_ir_var_name(var_idx: int) -> string {
    if var_idx >= 0 && var_idx < g_ir_var_count {
        return g_ir_vars[var_idx].name;
    }
    return "";
}

// --- Track string constants ---
fn track_str_const(str_idx: int) {
    let mut i = 0;
    loop {
        if i >= g_ir_str_const_count { break; }
        if g_ir_str_consts[i] == str_idx { return; }
        i = i + 1;
    }
    if g_ir_str_const_count < MAX_STRS {
        g_ir_str_consts[g_ir_str_const_count] = str_idx;
        g_ir_str_const_count = g_ir_str_const_count + 1;
    }
}

// --- Loop label stack ---
fn push_loop_labels(header: int, exit: int) {
    if g_ir_loop_depth < MAX_LOOPS {
        g_ir_loop_header[g_ir_loop_depth] = header;
        g_ir_loop_exit[g_ir_loop_depth] = exit;
        g_ir_loop_depth = g_ir_loop_depth + 1;
    }
}

fn pop_loop_labels() {
    if g_ir_loop_depth > 0 {
        g_ir_loop_depth = g_ir_loop_depth - 1;
    }
}

// --- IR generation for expressions ---
// Returns the IR variable index holding the result

fn ir_gen_expr(node: int) -> int {
    if node < 0 { return -1; }
    let n = g_ast[node];

    // Literals
    if n.kind == EXPR_INT {
        let v = new_ir_var("int", TI_INT);
        emit(IR_CONST, v, n.int_val, 0, 0, TI_INT);
        return v;
    }
    if n.kind == EXPR_FLOAT {
        let v = new_ir_var("float", TI_FLOAT);
        emit(IR_CONST, v, n.int_val, 0, 0, TI_FLOAT);
        return v;
    }
    if n.kind == EXPR_BOOL {
        let v = new_ir_var("bool", TI_BOOL);
        emit(IR_CONST, v, n.int_val, 0, 0, TI_BOOL);
        return v;
    }
    if n.kind == EXPR_STRING {
        let v = new_ir_var("str", TI_STR);
        let str_idx = n.int_val;
        track_str_const(str_idx);
        emit(IR_CONST, v, str_idx, 0, 0, TI_STR);
        return v;
    }
    if n.kind == EXPR_CHAR {
        let v = new_ir_var("char", TI_CHAR);
        let str_idx = n.int_val;
        track_str_const(str_idx);
        emit(IR_CONST, v, str_idx, 0, 0, TI_CHAR);
        return v;
    }

    // Identifier: local or global variable
    if n.kind == EXPR_IDENT {
        let name_idx = n.int_val;
        let lv = lookup_local(name_idx);
        if lv >= 0 { return lv; }
        let gv = lookup_global(name_idx);
        if gv >= 0 { return gv; }
        // Could be a function name being used as a value - return dummy
        let v = new_ir_var("unresolved", TI_UNIT);
        return v;
    }

    // Binary operation
    if n.kind == EXPR_BINARY {
        let left = n.a;
        let right = n.b;
        let op = n.c;

        // Assignment
        if op == OP_ASSIGN {
            let val_var = ir_gen_expr(right);
            // Determine lhs kind
            let lhs = g_ast[left];
            if lhs.kind == EXPR_IDENT {
                let name_idx = lhs.int_val;
                let target = lookup_local(name_idx);
                if target >= 0 {
                    emit(IR_STORE, -1, target, val_var, 0, 0);
                } else {
                    let gtarget = lookup_global(name_idx);
                    if gtarget >= 0 {
                        emit(IR_STORE, -1, gtarget, val_var, 0, 0);
                    }
                }
                return val_var;
            }
            if lhs.kind == EXPR_FIELD {
                let obj_var = ir_gen_expr(lhs.a);
                let field_ni = lhs.int_val;
                let fi = 0;
                emit(IR_STORE_FIELD, -1, obj_var, val_var, fi, 0);
                return val_var;
            }
            if lhs.kind == EXPR_INDEX {
                let arr_var = ir_gen_expr(lhs.a);
                let idx_node = lhs.b;
                let idx_kind = g_ast[idx_node].kind;
                if idx_kind == EXPR_INT {
                    emit(IR_STORE_INDEX, -1, arr_var, val_var, g_ast[idx_node].int_val, 0);
                } else {
                    let idx_var = ir_gen_expr(idx_node);
                    emit(IR_STORE_INDEX_VAR, val_var, arr_var, idx_var, 0, 0);
                }
                return val_var;
            }
            return val_var;
        }

        // Regular binary
        let left_var = ir_gen_expr(left);
        let right_var = ir_gen_expr(right);
        let v = new_ir_var("bin", TI_INT);
        emit(IR_BINARY, v, left_var, right_var, op, 0);
        return v;
    }

    // Unary operation
    if n.kind == EXPR_UNARY {
        let op = n.c;
        let op_var = ir_gen_expr(n.a);
        if op == UOP_REF {
            let v = new_ir_var("ref", TI_UNIT);
            emit(IR_REF, v, op_var, n.int_val, 0, 0);
            return v;
        }
        let v = new_ir_var("un", TI_INT);
        emit(IR_UNARY, v, op_var, 0, op, 0);
        return v;
    }

    // Function call
    if n.kind == EXPR_CALL {
        let func_node = n.a;
        let first_arg = n.b;
        let arg_count = n.c;
        let mut arg_vars: [int; 16];
        let mut ac = 0;
        let mut func_ni = -1;

        // Method call: obj.method(args)
        if g_ast[func_node].kind == EXPR_FIELD {
            let obj_node = g_ast[func_node].a;
            arg_vars[ac] = ir_gen_expr(obj_node); // self is first arg
            ac = ac + 1;
            func_ni = n.data; // mangled name stored by checker
        } else if g_ast[func_node].kind == EXPR_IDENT {
            func_ni = g_ast[func_node].int_val;
        }

        // Generate remaining args
        let mut an = first_arg;
        let mut i = 0;
        loop {
            if i >= arg_count { break; }
            if an >= 0 {
                arg_vars[ac] = ir_gen_expr(an);
                ac = ac + 1;
                an = an + 1;
            }
            i = i + 1;
        }
        let dest = new_ir_var("call", TI_UNIT);
        let first_arg_var = -1;
        if ac > 0 { first_arg_var = arg_vars[0]; }
        emit(IR_CALL, dest, first_arg_var, ac, func_ni, 0);
        return dest;
    }

    // Block
    if n.kind == EXPR_BLOCK {
        let stmt_start = n.a;
        let stmt_count = n.b;
        let mut last = -1;
        push_ir_scope();
        let mut i = 0;
        loop {
            if i >= stmt_count { break; }
            let sn = g_block_stmts[stmt_start + i];
            last = ir_gen_expr(sn);
            i = i + 1;
        }
        pop_ir_scope();
        return last;
    }

    // If expression
    if n.kind == EXPR_IF {
        let cond = n.a;
        let then_node = n.b;
        let else_node = n.c;
        let cond_var = ir_gen_expr(cond);
        let then_lbl = new_label();
        let else_lbl = new_label();
        let merge_lbl = new_label();
        if else_node >= 0 {
            emit(IR_BRANCH, -1, cond_var, then_lbl, else_lbl, 0);
        } else {
            emit(IR_BRANCH, -1, cond_var, then_lbl, merge_lbl, 0);
        }
        emit(IR_LABEL, -1, then_lbl, 0, 0, 0);
        ir_gen_expr(then_node);
        emit(IR_JUMP, -1, merge_lbl, 0, 0, 0);
        if else_node >= 0 {
            emit(IR_LABEL, -1, else_lbl, 0, 0, 0);
            ir_gen_expr(else_node);
            emit(IR_JUMP, -1, merge_lbl, 0, 0, 0);
        }
        emit(IR_LABEL, -1, merge_lbl, 0, 0, 0);
        return -1;
    }

    // Loop
    if n.kind == EXPR_LOOP {
        let header_lbl = new_label();
        let body_lbl = new_label();
        let exit_lbl = new_label();
        emit(IR_JUMP, -1, header_lbl, 0, 0, 0);
        emit(IR_LABEL, -1, header_lbl, 0, 0, 0);
        emit(IR_JUMP, -1, body_lbl, 0, 0, 0);
        emit(IR_LABEL, -1, body_lbl, 0, 0, 0);
        push_ir_scope();
        push_loop_labels(header_lbl, exit_lbl);
        ir_gen_expr(n.a);
        pop_loop_labels();
        pop_ir_scope();
        emit(IR_JUMP, -1, header_lbl, 0, 0, 0);
        emit(IR_LABEL, -1, exit_lbl, 0, 0, 0);
        return -1;
    }

    // While loop
    if n.kind == EXPR_WHILE {
        let cond = n.a;
        let body = n.b;
        let header_lbl = new_label();
        let body_lbl = new_label();
        let exit_lbl = new_label();
        emit(IR_LABEL, -1, header_lbl, 0, 0, 0);
        let cond_var = ir_gen_expr(cond);
        emit(IR_BRANCH, -1, cond_var, body_lbl, exit_lbl, 0);
        emit(IR_LABEL, -1, body_lbl, 0, 0, 0);
        push_ir_scope();
        push_loop_labels(header_lbl, exit_lbl);
        ir_gen_expr(body);
        pop_loop_labels();
        pop_ir_scope();
        emit(IR_JUMP, -1, header_lbl, 0, 0, 0);
        emit(IR_LABEL, -1, exit_lbl, 0, 0, 0);
        return -1;
    }

    // For loop
    if n.kind == EXPR_FOR {
        let var_ni = n.a;
        let iter = n.b;
        let body = n.c;
        // For now, handle range iterators: for x in 0..10 { body }
        // We iterate by evaluating iter (which should be a range expression)
        let iter_var = ir_gen_expr(iter);
        // Create loop variable
        let ivar = new_ir_var("for_i", TI_INT);
        emit(IR_ALLOC, ivar, 0, 0, 0, TI_INT);
        emit(IR_STORE, -1, ivar, iter_var, 0, 0);
        bind_local(var_ni, ivar);
        let header_lbl = new_label();
        let body_lbl = new_label();
        let exit_lbl = new_label();
        emit(IR_JUMP, -1, header_lbl, 0, 0, 0);
        emit(IR_LABEL, -1, header_lbl, 0, 0, 0);
        emit(IR_JUMP, -1, body_lbl, 0, 0, 0);
        emit(IR_LABEL, -1, body_lbl, 0, 0, 0);
        push_ir_scope();
        push_loop_labels(header_lbl, exit_lbl);
        ir_gen_expr(body);
        pop_loop_labels();
        pop_ir_scope();
        emit(IR_JUMP, -1, header_lbl, 0, 0, 0);
        emit(IR_LABEL, -1, exit_lbl, 0, 0, 0);
        return -1;
    }

    // Match expression
    if n.kind == EXPR_MATCH {
        let match_expr = n.a;
        let first_arm = n.b;
        let arm_count = n.c;
        ir_gen_expr(match_expr);
        let merge_lbl = new_label();
        let mut ai = 0;
        let mut an = first_arm;
        loop {
            if ai >= arm_count { break; }
            if an >= 0 {
                let arm_pat = g_ast[an].a;
                let arm_body = g_ast[an].b;
                let next_lbl = new_label();
                if arm_pat >= 0 && g_ast[arm_pat].kind == EXPR_WILDCARD {
                    // Wildcard arm: always match
                    emit(IR_JUMP, -1, next_lbl, 0, 0, 0);
                } else {
                    // Non-wildcard: branch (simplified)
                    emit(IR_JUMP, -1, next_lbl, 0, 0, 0);
                }
                emit(IR_LABEL, -1, next_lbl, 0, 0, 0);
                push_ir_scope();
                ir_gen_expr(arm_body);
                pop_ir_scope();
                emit(IR_JUMP, -1, merge_lbl, 0, 0, 0);
                an = an + 1;
            }
            ai = ai + 1;
        }
        emit(IR_LABEL, -1, merge_lbl, 0, 0, 0);
        return -1;
    }

    // Let binding
    if n.kind == EXPR_LET {
        let var_ni = n.a;
        let val_node = n.c;
        let var = new_ir_var(g_strs[var_ni], TI_UNIT);
        emit(IR_ALLOC, var, 0, 0, 0, TI_UNIT);
        if val_node >= 0 {
            let val_var = ir_gen_expr(val_node);
            emit(IR_STORE, -1, var, val_var, 0, 0);
        }
        bind_local(var_ni, var);
        return var;
    }

    // Return
    if n.kind == EXPR_RETURN {
        if n.a >= 0 {
            let val_var = ir_gen_expr(n.a);
            emit(IR_RETURN, -1, val_var, 0, 0, 0);
        } else {
            emit(IR_RETURN, -1, -1, 0, 0, 0);
        }
        return -1;
    }

    // Field access
    if n.kind == EXPR_FIELD {
        let obj_var = ir_gen_expr(n.a);
        let field_ni = n.int_val;
        let v = new_ir_var("field", TI_INT);
        // Look up field index from struct definition
        let fi = 0;
        emit(IR_LOAD_FIELD, v, obj_var, 0, fi, 0);
        return v;
    }

    // Index
    if n.kind == EXPR_INDEX {
        let arr_var = ir_gen_expr(n.a);
        let idx_node = n.b;
        let idx_kind = g_ast[idx_node].kind;
        let v = new_ir_var("elem", TI_INT);
        if idx_kind == EXPR_INT {
            emit(IR_LOAD_INDEX, v, arr_var, 0, g_ast[idx_node].int_val, 0);
        } else {
            let idx_var = ir_gen_expr(idx_node);
            emit(IR_LOAD_INDEX_VAR, v, arr_var, idx_var, 0, 0);
        }
        return v;
    }

    // Enum constructor
    if n.kind == EXPR_ENUM_CONSTRUCTOR {
        let name_idx = n.a;
        let s = new_ir_var("enum", TI_UNIT);
        emit(IR_MAKE_ENUM, s, name_idx, 0, 0, 0);
        let mut ai = 0;
        let mut an = n.b;
        loop {
            if ai >= n.c { break; }
            if an >= 0 {
                let val_var = ir_gen_expr(an);
                emit(IR_STORE_FIELD, -1, s, val_var, ai, 0);
                an = an + 1;
            }
            ai = ai + 1;
        }
        return s;
    }

    // Struct literal
    if n.kind == EXPR_STRUCT {
        let name_ni = n.a;
        let s = new_ir_var("struct", TI_UNIT);
        emit(IR_ALLOC_STRUCT, s, 0, 0, name_ni, 0);
        let mut fi = 0;
        let mut fn2 = n.b;
        loop {
            if fi >= n.c { break; }
            if fn2 >= 0 {
                // fn2 = field name node (EXPR_IDENT)
                // fn2+1 = field value node
                let field_ni = g_ast[fn2].int_val;
                let val_var = ir_gen_expr(fn2 + 1);
                let field_idx = fi;
                emit(IR_STORE_FIELD, -1, s, val_var, field_idx, 0);
                fn2 = fn2 + 2;
            }
            fi = fi + 1;
        }
        return s;
    }

    // Array literal
    if n.kind == EXPR_ARRAY {
        let v = new_ir_var("arr", TI_UNIT);
        emit(IR_ALLOC_ARRAY, v, n.b, 0, 0, 0);
        let mut ei = 0;
        let mut en = n.a;
        loop {
            if ei >= n.b { break; }
            if en >= 0 {
                let e_var = ir_gen_expr(en);
                emit(IR_STORE_INDEX, -1, v, e_var, ei, 0);
                en = en + 1;
            }
            ei = ei + 1;
        }
        return v;
    }

    // Range expression (evaluates both ends, returns end)
    if n.kind == EXPR_RANGE {
        ir_gen_expr(n.a);
        let end_var = ir_gen_expr(n.b);
        return end_var;
    }

    // Break / Continue
    if n.kind == EXPR_BREAK {
        if g_ir_loop_depth > 0 {
            emit(IR_JUMP, -1, g_ir_loop_exit[g_ir_loop_depth - 1], 0, 0, 0);
        }
        return -1;
    }
    if n.kind == EXPR_CONTINUE {
        if g_ir_loop_depth > 0 {
            emit(IR_JUMP, -1, g_ir_loop_header[g_ir_loop_depth - 1], 0, 0, 0);
        }
        return -1;
    }

    if n.kind == EXPR_WILDCARD { return -1; }
    if n.kind == EXPR_ENUMPAT { return -1; }
    if n.kind == EXPR_MOVE {
        return ir_gen_expr(n.a);
    }
    if n.kind == EXPR_STMT {
        ir_gen_expr(n.a);
        return -1;
    }

    return -1;
}

// --- Generate IR for one function ---

fn ir_gen_func(fi: int) {
    let fn_node = g_funcs[fi].ast_node;
    let f = g_ast[fn_node];
    let name_idx = f.a;
    let first_param = f.b;
    let param_count = f.c;
    let ret_ti = TI_UNIT;
    let body = f.data;

    // Record function metadata
    let func_idx = g_ir_func_count;
    g_ir_func_name_idx[func_idx] = name_idx;
    g_ir_func_ret_type[func_idx] = ret_ti;
    g_ir_func_instr_start[func_idx] = g_ir_instr_count;
    g_ir_func_var_start[func_idx] = g_ir_var_count;
    g_ir_func_param_count[func_idx] = param_count;

    // Create IR vars for params
    let mut pi = 0;
    let mut pn = first_param;
    loop {
        if pi >= param_count { break; }
        if pn < 0 { break; }
        let p = g_ast[pn];
        let pname_idx = p.a;
        let pname = g_strs[pname_idx];
        let pvar = new_ir_var(pname, TI_INT);
        // Bind param name
        bind_local(pname_idx, pvar);
        pi = pi + 1;
        pn = pn + 1;
    }

    // Generate body
    if body >= 0 {
        ir_gen_expr(body);
    }

    // Add return at end if not already terminated
    emit(IR_RETURN, -1, -1, 0, 0, 0);

    g_ir_func_instr_count[func_idx] = g_ir_instr_count - g_ir_func_instr_start[func_idx];
    g_ir_func_var_count[func_idx] = g_ir_var_count - g_ir_func_var_start[func_idx];
    g_ir_func_count = func_idx + 1;
}

// --- Initialize global IR vars from global lets ---

fn ir_gen_globals() {
    let mut i = 0;
    loop {
        if i >= g_global_let_count { break; }
        let node = g_global_lets[i];
        let n = g_ast[node];
        let name_idx = n.a;
        let name = g_strs[name_idx];
        let gvar = new_ir_var(name, TI_INT);
        g_ir_globals[g_ir_global_count * 2] = name_idx;
        g_ir_globals[g_ir_global_count * 2 + 1] = gvar;
        g_ir_global_count = g_ir_global_count + 1;
        i = i + 1;
    }
}

// --- Main entry ---

fn ir_gen_all() {
    g_ir_var_count = 0;
    g_ir_instr_count = 0;
    g_ir_func_count = 0;
    g_ir_local_count = 0;
    g_ir_local_depth = 0;
    g_ir_global_count = 0;
    g_next_label = 1;
    g_ir_loop_depth = 0;
    g_ir_str_const_count = 0;

    // Initialize globals
    ir_gen_globals();

    // Generate IR for each function
    let mut i = 0;
    loop {
        if i >= g_func_count { break; }
        ir_gen_func(i);
        i = i + 1;
    }
}

// === src/compiler/backend/x86_64.core ===
// === backend/x86_64.core ===
// x86-64 assembly generation from flat IR (GAS .intel_syntax noprefix)

// Stack frame management per function
let mut g_x86_vars: [int; MAX_IREXPRS]; // var_idx -> stack offset from rbp (negative)
let mut g_x86_var_count: int;
let mut g_x86_stack_size: int; // total stack frame size for current function

fn x86_init_frame() {
    g_x86_var_count = 0;
    g_x86_stack_size = 0;
}

fn x86_alloc_stack(var_idx: int) -> int {
    let mut i = 0;
    loop {
        if i >= g_x86_var_count { break; }
        if g_x86_vars[i] == var_idx {
            return -(i + 1) * 8;
        }
        i = i + 1;
    }
    if g_x86_var_count < MAX_IREXPRS {
        g_x86_vars[g_x86_var_count] = var_idx;
        g_x86_var_count = g_x86_var_count + 1;
        g_x86_stack_size = g_x86_var_count * 8;
        return -(g_x86_var_count) * 8;
    }
    return -8;
}

fn x86_get_offset(var_idx: int) -> int {
    let mut i = 0;
    loop {
        if i >= g_x86_var_count { break; }
        if g_x86_vars[i] == var_idx {
            return -(i + 1) * 8;
        }
        i = i + 1;
    }
    return x86_alloc_stack(var_idx);
}

fn x86_label(lbl: int) -> string {
    let mut s = ".L";
    s = s + __builtin_int_to_str(lbl);
    s = s + ":";
    return s;
}

fn x86_jump_label(lbl: int) -> string {
    let mut s = ".L";
    s = s + __builtin_int_to_str(lbl);
    return s;
}

fn x86_gen_instr(instr_idx: int) -> string {
    let inst = g_ir_instrs[instr_idx];
    let op = inst.opcode;
    let dest = inst.dest;
    let s1 = inst.src1;
    let s2 = inst.src2;
    let s3 = inst.src3;
    let mut asm = "";

    if op == IR_NOP { return asm; }

    if op == IR_CONST {
        let off = x86_get_offset(dest);
        let val = s1;
        let ti = inst.type_kind;
        if ti == TI_STR {
            let mut lbl = ".LC";
            lbl = lbl + __builtin_int_to_str(val);
            asm = asm + "    lea r10, ";
            asm = asm + lbl;
            asm = asm + "[rip]\n";
            asm = asm + "    mov [rbp";
            if off >= 0 { asm = asm + "+"; }
            asm = asm + __builtin_int_to_str(off);
            asm = asm + "], r10\n";
        } else {
            asm = asm + "    mov qword ptr [rbp";
            if off >= 0 { asm = asm + "+"; }
            asm = asm + __builtin_int_to_str(off);
            asm = asm + "], ";
            asm = asm + __builtin_int_to_str(val);
            asm = asm + "\n";
        }
        return asm;
    }

    if op == IR_BINARY {
        let off_s1 = x86_get_offset(s1);
        let off_s2 = x86_get_offset(s2);
        let off_d = x86_get_offset(dest);
        asm = asm + "    mov r10, [rbp";
        if off_s1 >= 0 { asm = asm + "+"; }
        asm = asm + __builtin_int_to_str(off_s1);
        asm = asm + "]\n";
        asm = asm + "    mov r11, [rbp";
        if off_s2 >= 0 { asm = asm + "+"; }
        asm = asm + __builtin_int_to_str(off_s2);
        asm = asm + "]\n";
        if s3 == OP_ADD { asm = asm + "    add r10, r11\n"; }
        if s3 == OP_SUB { asm = asm + "    sub r10, r11\n"; }
        if s3 == OP_MUL { asm = asm + "    imul r10, r11\n"; }
        if s3 == OP_DIV {
            asm = asm + "    mov rax, r10\n";
            asm = asm + "    cqo\n";
            asm = asm + "    idiv r11\n";
            asm = asm + "    mov r10, rax\n";
        }
        if s3 == OP_MOD {
            asm = asm + "    mov rax, r10\n";
            asm = asm + "    cqo\n";
            asm = asm + "    idiv r11\n";
            asm = asm + "    mov r10, rdx\n";
        }
        if s3 == OP_EQ {
            asm = asm + "    cmp r10, r11\n";
            asm = asm + "    sete al\n    movzx r10, al\n";
        }
        if s3 == OP_NE {
            asm = asm + "    cmp r10, r11\n";
            asm = asm + "    setne al\n    movzx r10, al\n";
        }
        if s3 == OP_LT {
            asm = asm + "    cmp r10, r11\n";
            asm = asm + "    setl al\n    movzx r10, al\n";
        }
        if s3 == OP_GT {
            asm = asm + "    cmp r10, r11\n";
            asm = asm + "    setg al\n    movzx r10, al\n";
        }
        if s3 == OP_LE {
            asm = asm + "    cmp r10, r11\n";
            asm = asm + "    setle al\n    movzx r10, al\n";
        }
        if s3 == OP_GE {
            asm = asm + "    cmp r10, r11\n";
            asm = asm + "    setge al\n    movzx r10, al\n";
        }
        if s3 == OP_AND { asm = asm + "    and r10, r11\n"; }
        if s3 == OP_OR { asm = asm + "    or r10, r11\n"; }
        asm = asm + "    mov [rbp";
        if off_d >= 0 { asm = asm + "+"; }
        asm = asm + __builtin_int_to_str(off_d);
        asm = asm + "], r10\n";
        return asm;
    }

    if op == IR_UNARY {
        let off_s1 = x86_get_offset(s1);
        let off_d = x86_get_offset(dest);
        asm = asm + "    mov r10, [rbp";
        if off_s1 >= 0 { asm = asm + "+"; }
        asm = asm + __builtin_int_to_str(off_s1);
        asm = asm + "]\n";
        if s3 == UOP_NEG { asm = asm + "    neg r10\n"; }
        else if s3 == UOP_NOT {
            asm = asm + "    cmp r10, 0\n";
            asm = asm + "    sete al\n    movzx r10, al\n";
        }
        asm = asm + "    mov [rbp";
        if off_d >= 0 { asm = asm + "+"; }
        asm = asm + __builtin_int_to_str(off_d);
        asm = asm + "], r10\n";
        return asm;
    }

    if op == IR_CALL {
        let func_ni = s3;
        let func_name = "";
        if func_ni >= 0 { func_name = g_strs[func_ni]; }
        let first_arg = s1;
        let arg_count = s2;
        let arg_regs = ["rdi", "rsi", "rdx", "rcx", "r8", "r9"];
        let mut ai = 0;
        loop {
            if ai >= arg_count { break; }
            if ai >= 6 { break; }
            let arg_var = first_arg + ai;
            let aoff = x86_get_offset(arg_var);
            asm = asm + "    mov ";
            asm = asm + arg_regs[ai];
            asm = asm + ", [rbp";
            if aoff >= 0 { asm = asm + "+"; }
            asm = asm + __builtin_int_to_str(aoff);
            asm = asm + "]\n";
            ai = ai + 1;
        }
        if func_name != "" && func_name != "__builtin_str_len" && func_name != "__builtin_str_get"
            && func_name != "__builtin_str_sub" && func_name != "__builtin_int_to_str"
            && func_name != "__builtin_str_to_int" && func_name != "__builtin_str_push"
            && func_name != "__builtin_str_from_int" {
            asm = asm + "    call ";
            asm = asm + func_name;
            asm = asm + "\n";
        } else {
            asm = asm + "    xor eax, eax\n";
        }
        if dest >= 0 {
            let doff = x86_get_offset(dest);
            asm = asm + "    mov [rbp";
            if doff >= 0 { asm = asm + "+"; }
            asm = asm + __builtin_int_to_str(doff);
            asm = asm + "], rax\n";
        }
        return asm;
    }

    if op == IR_RETURN {
        if s1 >= 0 {
            let off = x86_get_offset(s1);
            asm = asm + "    mov rax, [rbp";
            if off >= 0 { asm = asm + "+"; }
            asm = asm + __builtin_int_to_str(off);
            asm = asm + "]\n";
        }
        return asm;
    }

    if op == IR_ALLOC {
        x86_get_offset(dest);
        return asm;
    }

    if op == IR_ALLOC_STRUCT {
        x86_get_offset(dest);
        return asm;
    }

    if op == IR_ALLOC_ARRAY {
        x86_get_offset(dest);
        return asm;
    }

    if op == IR_STORE {
        let off_addr = x86_get_offset(s1);
        let off_val = x86_get_offset(s2);
        asm = asm + "    mov r10, [rbp";
        if off_val >= 0 { asm = asm + "+"; }
        asm = asm + __builtin_int_to_str(off_val);
        asm = asm + "]\n";
        asm = asm + "    mov [rbp";
        if off_addr >= 0 { asm = asm + "+"; }
        asm = asm + __builtin_int_to_str(off_addr);
        asm = asm + "], r10\n";
        return asm;
    }

    if op == IR_LOAD {
        let off_src = x86_get_offset(s1);
        let off_d = x86_get_offset(dest);
        asm = asm + "    mov r10, [rbp";
        if off_src >= 0 { asm = asm + "+"; }
        asm = asm + __builtin_int_to_str(off_src);
        asm = asm + "]\n";
        asm = asm + "    mov [rbp";
        if off_d >= 0 { asm = asm + "+"; }
        asm = asm + __builtin_int_to_str(off_d);
        asm = asm + "], r10\n";
        return asm;
    }

    if op == IR_LOAD_FIELD {
        let off_struct = x86_get_offset(s1);
        let off_d = x86_get_offset(dest);
        let field_idx = s3;
        asm = asm + "    mov r10, [rbp";
        if off_struct >= 0 { asm = asm + "+"; }
        asm = asm + __builtin_int_to_str(off_struct);
        asm = asm + "]\n";
        asm = asm + "    mov r11, [r10 + ";
        asm = asm + __builtin_int_to_str(field_idx * 8);
        asm = asm + "]\n";
        asm = asm + "    mov [rbp";
        if off_d >= 0 { asm = asm + "+"; }
        asm = asm + __builtin_int_to_str(off_d);
        asm = asm + "], r11\n";
        return asm;
    }

    if op == IR_STORE_FIELD {
        let off_struct = x86_get_offset(s1);
        let off_val = x86_get_offset(s2);
        let field_idx = s3;
        asm = asm + "    mov r10, [rbp";
        if off_struct >= 0 { asm = asm + "+"; }
        asm = asm + __builtin_int_to_str(off_struct);
        asm = asm + "]\n";
        asm = asm + "    mov r11, [rbp";
        if off_val >= 0 { asm = asm + "+"; }
        asm = asm + __builtin_int_to_str(off_val);
        asm = asm + "]\n";
        asm = asm + "    mov [r10 + ";
        asm = asm + __builtin_int_to_str(field_idx * 8);
        asm = asm + "], r11\n";
        return asm;
    }

    if op == IR_LOAD_INDEX {
        let off_arr = x86_get_offset(s1);
        let off_d = x86_get_offset(dest);
        let idx = s3;
        asm = asm + "    mov r10, [rbp";
        if off_arr >= 0 { asm = asm + "+"; }
        asm = asm + __builtin_int_to_str(off_arr);
        asm = asm + "]\n";
        asm = asm + "    mov r11, [r10 + ";
        asm = asm + __builtin_int_to_str(idx * 8);
        asm = asm + "]\n";
        asm = asm + "    mov [rbp";
        if off_d >= 0 { asm = asm + "+"; }
        asm = asm + __builtin_int_to_str(off_d);
        asm = asm + "], r11\n";
        return asm;
    }

    if op == IR_STORE_INDEX {
        let off_arr = x86_get_offset(s1);
        let off_val = x86_get_offset(s2);
        let idx = s3;
        asm = asm + "    mov r10, [rbp";
        if off_arr >= 0 { asm = asm + "+"; }
        asm = asm + __builtin_int_to_str(off_arr);
        asm = asm + "]\n";
        asm = asm + "    mov r11, [rbp";
        if off_val >= 0 { asm = asm + "+"; }
        asm = asm + __builtin_int_to_str(off_val);
        asm = asm + "]\n";
        asm = asm + "    mov [r10 + ";
        asm = asm + __builtin_int_to_str(idx * 8);
        asm = asm + "], r11\n";
        return asm;
    }

    if op == IR_LOAD_INDEX_VAR {
        let off_arr = x86_get_offset(s1);
        let off_idx = x86_get_offset(s2);
        let off_d = x86_get_offset(dest);
        asm = asm + "    mov r10, [rbp";
        if off_arr >= 0 { asm = asm + "+"; }
        asm = asm + __builtin_int_to_str(off_arr);
        asm = asm + "]\n";
        asm = asm + "    mov r11, [rbp";
        if off_idx >= 0 { asm = asm + "+"; }
        asm = asm + __builtin_int_to_str(off_idx);
        asm = asm + "]\n";
        asm = asm + "    mov r12, [r10 + r11 * 8]\n";
        asm = asm + "    mov [rbp";
        if off_d >= 0 { asm = asm + "+"; }
        asm = asm + __builtin_int_to_str(off_d);
        asm = asm + "], r12\n";
        return asm;
    }

    if op == IR_STORE_INDEX_VAR {
        let off_arr = x86_get_offset(s1);
        let off_idx = x86_get_offset(s2);
        let off_val = x86_get_offset(dest);
        asm = asm + "    mov r10, [rbp";
        if off_arr >= 0 { asm = asm + "+"; }
        asm = asm + __builtin_int_to_str(off_arr);
        asm = asm + "]\n";
        asm = asm + "    mov r11, [rbp";
        if off_idx >= 0 { asm = asm + "+"; }
        asm = asm + __builtin_int_to_str(off_idx);
        asm = asm + "]\n";
        asm = asm + "    mov r12, [rbp";
        if off_val >= 0 { asm = asm + "+"; }
        asm = asm + __builtin_int_to_str(off_val);
        asm = asm + "]\n";
        asm = asm + "    mov [r10 + r11 * 8], r12\n";
        return asm;
    }

    if op == IR_MAKE_ENUM {
        x86_get_offset(dest);
        return asm;
    }
    if op == IR_REF { return asm; }

    if op == IR_BRANCH {
        let off_cond = x86_get_offset(s1);
        let true_lbl = s2;
        let false_lbl = s3;
        asm = asm + "    mov r10, [rbp";
        if off_cond >= 0 { asm = asm + "+"; }
        asm = asm + __builtin_int_to_str(off_cond);
        asm = asm + "]\n";
        asm = asm + "    cmp r10, 1\n";
        asm = asm + "    je  ";
        asm = asm + x86_jump_label(true_lbl);
        asm = asm + "\n    jmp ";
        asm = asm + x86_jump_label(false_lbl);
        asm = asm + "\n";
        return asm;
    }

    if op == IR_JUMP {
        asm = asm + "    jmp ";
        asm = asm + x86_jump_label(s1);
        asm = asm + "\n";
        return asm;
    }

    if op == IR_LABEL {
        asm = asm + x86_label(s1);
        asm = asm + "\n";
        return asm;
    }

    if op == IR_PHI { return asm; }
    return asm;
}

fn x86_gen_function(func_idx: int) -> string {
    let name_idx = g_ir_func_name_idx[func_idx];
    let func_name = g_strs[name_idx];
    let instr_start = g_ir_func_instr_start[func_idx];
    let instr_count = g_ir_func_instr_count[func_idx];
    let var_count = g_ir_func_var_count[func_idx];
    let var_start = g_ir_func_var_start[func_idx];

    let mut asm = "";

    if func_name == "main" {
        asm = asm + "_start:\n";
    } else {
        asm = asm + func_name;
        asm = asm + ":\n";
    }

    asm = asm + "    push rbp\n    mov rbp, rsp\n";

    x86_init_frame();
    let mut vi = 0;
    loop {
        if vi >= var_count { break; }
        x86_alloc_stack(var_start + vi);
        vi = vi + 1;
    }

    if g_x86_stack_size > 0 {
        asm = asm + "    sub rsp, ";
        asm = asm + __builtin_int_to_str(g_x86_stack_size);
        asm = asm + "\n";
    }

    let mut i = 0;
    loop {
        if i >= instr_count { break; }
        let instr_asm = x86_gen_instr(instr_start + i);
        asm = asm + instr_asm;
        i = i + 1;
    }

    if func_name == "main" {
        asm = asm + "    mov edi, eax\n    mov eax, 60\n    syscall\n";
    } else {
        if g_x86_stack_size > 0 {
            asm = asm + "    add rsp, ";
            asm = asm + __builtin_int_to_str(g_x86_stack_size);
            asm = asm + "\n";
        }
        asm = asm + "    pop rbp\n    ret\n";
    }
    asm = asm + "\n";
    return asm;
}

fn x86_64_generate() -> string {
    let mut asm = "";
    asm = asm + ".intel_syntax noprefix\n.text\n.globl _start\n\n";

    let mut i = 0;
    loop {
        if i >= g_ir_func_count { break; }
        asm = asm + x86_gen_function(i);
        i = i + 1;
    }

    asm = asm + ".section .rodata\n";
    let mut si = 0;
    loop {
        if si >= g_ir_str_const_count { break; }
        let str_idx = g_ir_str_consts[si];
        let mut lbl = ".LC";
        lbl = lbl + __builtin_int_to_str(si);
        lbl = lbl + ": .asciz \"";
        lbl = lbl + g_strs[str_idx];
        lbl = lbl + "\"\n";
        asm = asm + lbl;
        si = si + 1;
    }

    return asm;
}

// === src/compiler/main.core ===
// === main.core ===
// Compiler entry point: ties all stages together

// Entry for build verification (no args)
fn compiler_entry() -> string {
    return "compiler_ok";
}

// Full compilation: source -> assembly
fn compile_source(source: string) -> string {
    g_source = source;
    tokenize();
    parse_all();
    check_all();
    if g_check_error_count > 0 {
        let mut err_msg = "check errors:";
        let mut ei = 0;
        loop {
            if ei >= g_check_error_count { break; }
            err_msg = err_msg + " " + g_check_errors[ei];
            ei = ei + 1;
        }
        return err_msg;
    }
    ir_gen_all();
    return x86_64_generate();
}